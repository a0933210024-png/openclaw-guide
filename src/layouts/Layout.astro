---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
  currentPath?: string;
  ogImage?: string;
}

const { title, description = "AI 產業地圖與助理指南", lang = "zh", currentPath = "/", ogImage = "https://openclaw-guide-red.vercel.app/og-image.png" } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — MiniBot</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
  </head>
  <body>
    <!-- 頂部導航 - 毛玻璃效果 -->
    <nav class="glass-nav">
      <div class="nav-container">
        <a href="/" class="brand">
          <svg class="brand-logo" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M12 2L2 22h20L12 2z" fill="url(#brand-gradient)" />
            <defs>
              <linearGradient id="brand-gradient" x1="12" y1="2" x2="12" y2="22" gradientUnits="userSpaceOnUse">
                <stop stop-color="#38bdf8" />
                <stop offset="1" stop-color="#3b82f6" fill-opacity="0.8" />
              </linearGradient>
            </defs>
          </svg>
          <span class="brand-text">MiniBot</span>
        </a>
        <div class="nav-links">
          <a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a>
          <a href="/industry" class={currentPath.includes('/industry') ? 'active' : ''}>Industry</a>
          <a href="/news" class={currentPath.includes('/news') ? 'active' : ''}>News</a>
          <a href="/guide/install" class={currentPath.includes('/guide') ? 'active' : ''}>Docs</a>
        </div>
        <div class="flex items-center gap-4">
          <button id="cmd-k-btn" class="hidden md:flex items-center gap-3 px-3 py-1.5 rounded-md border border-white/10 bg-white/5 hover:bg-white/10 text-sm text-gray-400 font-mono transition-colors">
            <span>Search...</span>
            <span class="flex items-center gap-1 px-1.5 py-0.5 rounded bg-black/50 border border-white/5 text-[10px]"><kbd>⌘</kbd><kbd>K</kbd></span>
          </button>
          <button class="mobile-menu-btn" aria-label="Menu" id="mobile-menu-btn">
            <span></span><span></span><span></span>
          </button>
        </div>
      </div>
      
      <!-- 手機版選單 dropdown -->
      <div class="mobile-menu" id="mobile-menu">
        <a href="/" class={currentPath === '/' ? 'active' : ''}>Home</a>
        <a href="/industry" class={currentPath.includes('/industry') ? 'active' : ''}>Industry</a>
        <a href="/news" class={currentPath.includes('/news') ? 'active' : ''}>News</a>
        <a href="/guide/install" class={currentPath.includes('/guide') ? 'active' : ''}>Docs</a>
      </div>
    </nav>

    <!-- Command Palette Modal -->
    <div id="cmd-palette" class="fixed inset-0 z-[100] hidden">
      <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" id="cmd-backdrop"></div>
      <div class="absolute top-[15%] left-1/2 -translate-x-1/2 w-full max-w-2xl px-4">
        <div class="bg-[#111] border border-white/10 rounded-xl shadow-2xl overflow-hidden flex flex-col">
          <div class="flex items-center px-4 border-b border-white/5">
            <svg class="w-5 h-5 text-gray-400 mr-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" id="cmd-input" class="w-full bg-transparent border-none outline-none text-white py-4 text-lg placeholder-gray-500 font-sans" placeholder="Search resources, models, or trackers..." autocomplete="off" />
            <kbd class="hidden sm:inline-block px-2 py-1 bg-white/5 rounded border border-white/10 text-[10px] text-gray-400 font-mono">ESC</kbd>
          </div>
          <div class="p-2 max-h-[60vh] overflow-y-auto" id="cmd-results">
             <!-- Results injected via JS -->
          </div>
          <div class="bg-[#0a0a0a] border-t border-white/5 p-3 text-xs text-center text-gray-500 flex justify-between px-4">
             <span>Navigate: <kbd class="font-mono bg-white/5 px-1 rounded">↑</kbd> <kbd class="font-mono bg-white/5 px-1 rounded">↓</kbd></span>
             <span>Select: <kbd class="font-mono bg-white/5 px-1 rounded">↵</kbd></span>
          </div>
        </div>
      </div>
    </div>

    <main class="page-main">
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-container">
        <div class="footer-top">
          <div class="brand">
             <span class="brand-text">MiniBot</span>
          </div>
          <div class="footer-links">
             <a href="https://docs.openclaw.ai">OpenClaw Docs</a>
             <a href="https://github.com/a0933210024-png/openclaw-guide">GitHub</a>
          </div>
        </div>
        <p class="footer-copy">© 2026 MiniBot AI Hub. Built for the next era.</p>
      </div>
    </footer>

    <script>
      // 處理手機版導航與下拉選單
      const btn = document.getElementById('mobile-menu-btn');
      const menu = document.getElementById('mobile-menu');
      if(btn && menu) {
        btn.addEventListener('click', () => {
          btn.classList.toggle('open');
          menu.classList.toggle('open');
        });
      }

      // Command Palette Logic
      const cmdBtn = document.getElementById('cmd-k-btn');
      const palette = document.getElementById('cmd-palette');
      const backdrop = document.getElementById('cmd-backdrop');
      const input = document.getElementById('cmd-input');
      const resultsContainer = document.getElementById('cmd-results');
      
      const commands = [
        { title: "NVIDIA (NVDA)", desc: "View Silicon & Compute ecosystem", url: "/industry" },
        { title: "Install Guide: Telegram", desc: "Deploy MiniBot to Telegram", url: "/guide/telegram" },
        { title: "Install Guide: Discord", desc: "Deploy MiniBot to Discord", url: "/guide/discord" },
        { title: "Neural Daily Briefing", desc: "Read latest AI funding and research news", url: "/news" },
        { title: "OpenAI Models", desc: "View latest Foundation Models", url: "/industry" },
        { title: "Meta Open Source", desc: "Llama architecture insights", url: "/news" }
      ];

      function renderResults(query) {
        if(!resultsContainer) return;
        const q = (query || '').toLowerCase();
        let filtered = commands.filter(c => c.title.toLowerCase().includes(q) || c.desc.toLowerCase().includes(q));
        if(!q) filtered = commands.slice(0,4); // default suggestions
        
        if(filtered.length === 0) {
          resultsContainer.innerHTML = `<div class="p-4 text-gray-500 text-sm text-center">No results found for "${query}"</div>`;
          return;
        }

        resultsContainer.innerHTML = filtered.map((c, i) => `
          <a href="${c.url}" class="flex items-center justify-between p-3 rounded-lg hover:bg-white/10 transition-colors group ${i === 0 && q ? 'bg-white/5 border border-white/10' : ''}">
             <div>
               <div class="text-white font-medium mb-1 group-hover:text-blue-400">${c.title}</div>
               <div class="text-xs text-gray-500">${c.desc}</div>
             </div>
             <svg class="w-4 h-4 text-gray-600 group-hover:text-blue-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
             </svg>
          </a>
        `).join('');
      }

      function togglePalette(force) {
        if(!palette) return;
        const isHidden = palette.classList.contains('hidden');
        if(typeof force === 'boolean') {
          if(force) openPalette(); else closePalette();
          return;
        }
        if(isHidden) openPalette(); else closePalette();
      }

      function openPalette() {
        palette.classList.remove('hidden');
        palette.classList.add('flex');
        input?.focus();
        renderResults('');
        document.body.style.overflow = 'hidden';
      }

      function closePalette() {
        palette.classList.add('hidden');
        palette.classList.remove('flex');
        if(input) input.value = '';
        document.body.style.overflow = '';
      }

      cmdBtn?.addEventListener('click', () => togglePalette(true));
      backdrop?.addEventListener('click', () => togglePalette(false));
      input?.addEventListener('input', (e) => renderResults(e.target.value));

      document.addEventListener('keydown', (e) => {
        // Cmd/Ctrl + K
        if ((e.metaKey || e.ctrlKey) && e.key === 'k') {
          e.preventDefault();
          togglePalette();
        }
        // ESC
        if (e.key === 'Escape' && !palette?.classList.contains('hidden')) {
          e.preventDefault();
          togglePalette(false);
        }
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* 現代科技灰階 (Vercel / Linear 風格) */
    --bg-main: #0a0a0a;
    --bg-card: #111111;
    --bg-card-hover: #171717;
    --bg-element: #1a1a1a;
    
    --border-light: rgba(255, 255, 255, 0.08);
    --border-strong: rgba(255, 255, 255, 0.15);
    
    --text-primary: #f5f5f5;
    --text-secondary: #a3a3a3;
    --text-tertiary: #525252;
    
    /* 點綴色: 科技藍與霓虹青 */
    --accent: #38bdf8;
    --accent-glow: rgba(56, 189, 248, 0.4);
    
    --font-sans: 'Inter', -apple-system, sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
    
    --radius-sm: 6px;
    --radius-md: 12px;
    --radius-lg: 20px;
  }

  html { background: var(--bg-main); color: var(--text-primary); font-family: var(--font-sans); }

  body {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
  }

  a { color: inherit; text-decoration: none; transition: color 0.2s ease; }
  
  /* --- Navigation --- */
  .glass-nav {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(10, 10, 10, 0.6);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border-bottom: 1px solid var(--border-light);
  }

  .nav-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .brand-logo { width: 24px; height: 24px; }
  .brand-text { font-weight: 700; font-size: 1.1rem; letter-spacing: -0.02em; }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  .nav-links a {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--text-secondary);
  }
  .nav-links a:hover, .nav-links a.active { color: var(--text-primary); }

  /* Mobile menu button */
  .mobile-menu-btn {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    flex-direction: column;
    gap: 5px;
    padding: 0.5rem;
    z-index: 60;
  }
  .mobile-menu-btn span {
    display: block;
    width: 20px;
    height: 2px;
    background: var(--text-primary);
    transition: 0.3s;
  }

  .mobile-menu {
    display: none;
    background: var(--bg-main);
    border-top: 1px solid var(--border-light);
  }
  .mobile-menu a {
    display: block;
    padding: 1rem 1.5rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
    font-weight: 500;
  }
  .mobile-menu a.active { color: var(--accent); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .mobile-menu-btn { display: flex; }
    .mobile-menu.open { display: block; }
  }

  /* --- Main Content --- */
  .page-main {
    flex: 1;
    width: 100%;
    margin: 0 auto;
  }

  /* --- Footer --- */
  .footer {
    border-top: 1px solid var(--border-light);
    background: var(--bg-card);
    padding: 3rem 1.5rem;
    margin-top: 4rem;
  }
  .footer-container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }
  .footer-links {
    display: flex;
    gap: 1.5rem;
  }
  .footer-links a {
    color: var(--text-secondary);
    font-size: 0.9rem;
  }
  .footer-links a:hover { color: var(--text-primary); }
  .footer-copy {
    color: var(--text-tertiary);
    font-size: 0.85rem;
  }

  @media (max-width: 600px) {
    .footer-top { flex-direction: column; align-items: flex-start; gap: 1.5rem; }
  }

  /* --- Common Utility Classes --- */
  /* Glass Cards */
  .glass-card {
    background: var(--bg-card);
    border: 1px solid var(--border-light);
    border-radius: var(--radius-md);
    padding: 1.5rem;
    transition: all 0.2s ease;
  }
  .glass-card:hover { border-color: var(--border-strong); background: var(--bg-card-hover); }
  
  /* Badges */
  .badge {
    display: inline-flex;
    align-items: center;
    padding: 0.25rem 0.6rem;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid var(--border-light);
    border-radius: 99px;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--text-secondary);
  }
  .badge-blue { color: var(--accent); background: rgba(56, 189, 248, 0.1); border-color: rgba(56, 189, 248, 0.2); }
  
  /* Markdown Content Typography (For Markdown Pages) */
  .prose {
    color: var(--text-secondary);
    line-height: 1.7;
  }
  .prose h1, .prose h2, .prose h3 { color: var(--text-primary); margin-top: 2em; margin-bottom: 1em; font-weight: 600; letter-spacing: -0.02em; }
  .prose p { margin-bottom: 1.25em; }
  .prose a { color: var(--accent); text-decoration: underline; text-decoration-color: rgba(56,189,248,0.3); }
  .prose code { background: var(--bg-element); font-family: var(--font-mono); padding: 0.2em 0.4em; border-radius: 4px; font-size: 0.9em; }
  .prose pre { background: black; padding: 1.5em; border-radius: var(--radius-md); overflow-x: auto; border: 1px solid var(--border-light); }
  .prose pre code { background: transparent; padding: 0; color: #e5e5e5; }
  
  /* Utils for Command Palette */
  .fixed { position: fixed; }
  .absolute { position: absolute; }
  .inset-0 { top: 0; right: 0; bottom: 0; left: 0; }
  .top-\[15\%\] { top: 15%; }
  .left-1\/2 { left: 50%; }
  .-translate-x-1\/2 { transform: translateX(-50%); }
  .w-full { width: 100%; }
  .max-w-2xl { max-width: 42rem; }
  .max-h-\[60vh\] { max-height: 60vh; }
  .overflow-hidden { overflow: hidden; }
  .overflow-y-auto { overflow-y: auto; }
  
  .bg-\[\#111\] { background-color: #111; }
  .bg-\[\#0a0a0a\] { background-color: #0a0a0a; }
  .bg-black\/60 { background-color: rgba(0,0,0,0.6); }
  .bg-black\/50 { background-color: rgba(0,0,0,0.5); }
  .bg-white\/10 { background-color: rgba(255,255,255,0.1); }
  .bg-white\/5 { background-color: rgba(255,255,255,0.05); }
  .bg-transparent { background-color: transparent; }
  
  .m-0 { margin: 0; }
  .p-2 { padding: 0.5rem; }
  .p-3 { padding: 0.75rem; }
  .p-4 { padding: 1rem; }
  .px-4 { padding-left: 1rem; padding-right: 1rem; }
  .py-4 { padding-top: 1rem; padding-bottom: 1rem; }
  .px-3 { padding-left: 0.75rem; padding-right: 0.75rem; }
  .py-1\.5 { padding-top: 0.375rem; padding-bottom: 0.375rem; }
  .px-1\.5 { padding-left: 0.375rem; padding-right: 0.375rem; }
  .py-0\.5 { padding-top: 0.125rem; padding-bottom: 0.125rem; }
  .px-1 { padding-left: 0.25rem; padding-right: 0.25rem; }
  .px-2 { padding-left: 0.5rem; padding-right: 0.5rem; }
  .py-1 { padding-top: 0.25rem; padding-bottom: 0.25rem; }
  .mr-3 { margin-right: 0.75rem; }
  .mb-1 { margin-bottom: 0.25rem; }
  
  .gap-3 { gap: 0.75rem; }
  .gap-4 { gap: 1rem; }
  .gap-1 { gap: 0.25rem; }
  
  .border { border-width: 1px; }
  .border-b { border-bottom-width: 1px; }
  .border-t { border-top-width: 1px; }
  .border-white\/10 { border-color: rgba(255,255,255,0.1); }
  .border-white\/5 { border-color: rgba(255,255,255,0.05); }
  .border-none { border-style: none; }
  
  .rounded-md { border-radius: 0.375rem; }
  .rounded-lg { border-radius: 0.5rem; }
  .rounded-xl { border-radius: 0.75rem; }
  .rounded { border-radius: 0.25rem; }
  
  .shadow-2xl { box-shadow: 0 25px 50px -12px rgba(0,0,0,0.25); }
  .backdrop-blur-sm { backdrop-filter: blur(4px); -webkit-backdrop-filter: blur(4px); }
  .outline-none { outline: 2px solid transparent; outline-offset: 2px; }
  
  .text-white { color: #fff; }
  .text-gray-400 { color: #9ca3af; }
  .text-gray-500 { color: #6b7280; }
  .text-gray-600 { color: #4b5563; }
  .text-blue-400 { color: #60a5fa; }
  
  .text-\[10px\] { font-size: 10px; line-height: 1; }
  .text-xs { font-size: 0.75rem; line-height: 1rem; }
  .text-sm { font-size: 0.875rem; line-height: 1.25rem; }
  .text-lg { font-size: 1.125rem; line-height: 1.75rem; }
  .text-center { text-align: center; }
  
  .font-medium { font-weight: 500; }
  .font-sans { font-family: var(--font-sans); }
  
  .flex { display: flex; }
  .hidden { display: none; }
  .inline-block { display: inline-block; }
  .justify-between { justify-content: space-between; }
  
  .w-5 { width: 1.25rem; }
  .h-5 { height: 1.25rem; }
  .w-4 { width: 1rem; }
  .h-4 { height: 1rem; }
  
  .hover\:bg-white\/10:hover { background-color: rgba(255,255,255,0.1); }
  .hover\:text-blue-400:hover { color: #60a5fa; }
  
  .group:hover .group-hover\:text-blue-400 { color: #60a5fa; }
  .transition-colors { transition-property: background-color, border-color, color, fill, stroke; transition-timing-function: cubic-bezier(0.4, 0, 0.2, 1); transition-duration: 150ms; }
  .z-\[100\] { z-index: 100; }
  
  @media (min-width: 640px) {
    .sm\:inline-block { display: inline-block; }
  }
  @media (min-width: 768px) {
    .md\:flex { display: flex; }
  }
</style>
