---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
  currentPath?: string;
  ogImage?: string;
}

const { title, description = "MiniBot（迷你兵）— 最簡單的 AI 助理入門教學，手把手教你在手機上使用 AI Bot", lang = "en", currentPath = "/", ogImage = "https://openclaw-guide-red.vercel.app/og-image.png" } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — MiniBot</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;600&display=swap" rel="stylesheet">
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description || 'MiniBot（迷你兵）— 最簡單的 AI 助理入門教學'} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:image" content={ogImage} />
    <meta property="og:site_name" content="MiniBot" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content="@MiniBot_AI" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description || 'MiniBot（迷你兵）— 最簡單的 AI 助理入門教學'} />
    <link rel="canonical" href={`https://openclaw-guide-red.vercel.app${currentPath || '/'}`} />
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "WebSite",
        "name": "AI 趨勢園地 | MiniBot",
        "url": "https://openclaw-guide-red.vercel.app",
        "description": "掌握 AI 產業每一個關鍵動態",
        "potentialAction": {
          "@type": "SearchAction",
          "target": "https://openclaw-guide-red.vercel.app/news?q={search_term_string}",
          "query-input": "required name=search_term_string"
        }
      }
    </script>
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="logo-icon">🦞</span>
          <span class="logo-text">MiniBot</span>
          <span class="logo-subtitle">AI 趨勢園地</span>
        </a>
        <div class="nav-links">
          {lang === "en" ? (
            <>
              <a href="/" class={currentPath === '/' ? 'active' : ''}>🏠 Home</a>
              <a href="/industry" class={currentPath.includes('/industry') ? 'active' : ''}>🔭 AI Industry</a>
              <a href="/news" class={currentPath.includes('/news') ? 'active' : ''}>📰 AI News</a>
              <a href="/guide/install" class={currentPath.includes('/guide') ? 'active' : ''}>📚 Beginner Guide</a>
            </>
          ) : (
            <>
              <a href="/" class={currentPath === '/' ? 'active' : ''}>🏠 首頁</a>
              <a href="/industry" class={currentPath.includes('/industry') ? 'active' : ''}>🔭 AI 產業</a>
              <a href="/news" class={currentPath.includes('/news') ? 'active' : ''}>📰 AI 新聞</a>
              <a href="/guide/install" class={currentPath.includes('/guide') ? 'active' : ''}>📚 新手指南</a>
            </>
          )}
          <div class="lang-switcher">
            {lang === "en" ? (
              <a href={currentPath.replace(/^\/(?!zh)/, '/zh/')} class="lang-btn lang-zh">中文</a>
            ) : (
              <a href={currentPath.replace(/^\/zh/, '')} class="lang-btn lang-en">EN</a>
            )}
          </div>
          <button class="theme-toggle" id="theme-toggle" aria-label="切換主題">
            <span class="theme-icon">☀️</span>
          </button>
        </div>
        <button class="hamburger" id="hamburger" aria-label="Menu">
          <span></span><span></span><span></span>
        </button>
      </div>
    </nav>

    <main>
      <slot />
    </main>

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-brand">
          <span class="logo-icon">🦞</span>
          <span>MiniBot</span>
        </div>
        <p class="footer-desc">
          {lang === "en" 
            ? "MiniBot — An unofficial guide to OpenClaw, the self-hosted AI gateway."
            : "MiniBot（迷你兵）— OpenClaw 非官方教學，自架 AI 助理閘道器。"}
        </p>
        <div class="footer-links">
          <a href="https://docs.openclaw.ai" target="_blank" rel="noopener noreferrer">Official Docs</a>
          <a href="https://github.com" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
        <p class="footer-copy">&copy; 2026 MiniBot. MIT License.</p>
      </div>
    </footer>

    <script>
      const hamburger = document.getElementById('hamburger');
      const navLinks = document.querySelector('.nav-links');

      // P1: Hamburger toggle
      if (hamburger && navLinks) {
        hamburger.addEventListener('click', () => {
          navLinks.classList.toggle('open');
          hamburger.classList.toggle('active');
        });
        // Close menu when clicking any nav link
        navLinks.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            navLinks.classList.remove('open');
            hamburger.classList.remove('active');
          });
        });
      }

      // Dropdown nav
      document.querySelectorAll('.nav-dropdown').forEach(dropdown => {
        const btn = dropdown.querySelector('.nav-dropdown-btn');
        btn?.addEventListener('click', (e) => {
          e.stopPropagation();
          dropdown.classList.toggle('open');
          btn.setAttribute('aria-expanded', dropdown.classList.contains('open') ? 'true' : 'false');
        });
        // P2: Close dropdown when clicking a link inside it
        dropdown.querySelectorAll('a').forEach(link => {
          link.addEventListener('click', () => {
            dropdown.classList.remove('open');
            dropdown.querySelector('.nav-dropdown-btn')?.setAttribute('aria-expanded', 'false');
          });
        });
      });
      // Close dropdown when clicking outside
      document.addEventListener('click', () => {
        document.querySelectorAll('.nav-dropdown.open').forEach(d => {
          d.classList.remove('open');
          d.querySelector('.nav-dropdown-btn')?.setAttribute('aria-expanded', 'false');
        });
      });

      // P9: Active state for nav links
      const currentPath = window.location.pathname;
      document.querySelectorAll('.nav-links a').forEach(link => {
        const href = link.getAttribute('href');
        if (href && href !== '/' && href !== '/zh/' && currentPath.startsWith(href)) {
          link.classList.add('active');
        } else if ((href === '/' || href === '/zh/') && (currentPath === href || currentPath === href.replace(/\/$/, ''))) {
          link.classList.add('active');
        }
      });

      // Theme toggle
      const toggle = document.getElementById('theme-toggle');
      const icon = toggle?.querySelector('.theme-icon');
      const savedTheme = localStorage.getItem('theme') || 'dark';
      document.documentElement.setAttribute('data-theme', savedTheme);
      if (icon) icon.textContent = savedTheme === 'dark' ? '☀️' : '🌙';


      // Add copy buttons for code blocks
      document.querySelectorAll('pre').forEach((pre) => {
        if (pre.querySelector('.copy-btn')) return;
        const code = pre.querySelector('code');
        if (!code) return;
        const btn = document.createElement('button');
        btn.className = 'copy-btn';
        btn.type = 'button';
        btn.textContent = 'Copy';
        btn.addEventListener('click', async () => {
          const text = code.textContent || '';
          try {
            await navigator.clipboard.writeText(text);
            btn.textContent = 'Copied';
            setTimeout(() => (btn.textContent = 'Copy'), 1200);
          } catch {
            btn.textContent = 'Failed';
            setTimeout(() => (btn.textContent = 'Copy'), 1200);
          }
        });
        pre.appendChild(btn);
      });

      toggle?.addEventListener('click', () => {
        const current = document.documentElement.getAttribute('data-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', next);
        localStorage.setItem('theme', next);
        if (icon) icon.textContent = next === 'dark' ? '☀️' : '🌙';
      });
    </script>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    /* 背景層次 - 科技媒體深色調 */
    --bg: #0d0d0f;
    --bg2: #141416;
    --bg3: #1c1c1f;
    --bg4: #242428;
    
    /* 邊框 - 更精細 */
    --border: #2a2a30;
    --border-light: #38383f;
    
    /* 文字層次 - Apple 風格 */
    --text: #f5f5f7;
    --text2: #a0a0a8;
    --text3: #6b6b72;
    
    /* Accent - 冷色調科技感 */
    --accent: #e8f4fd;
    --accent2: #4fc3f7;
    --accent-bright: #4fc3f7;
    --accent-hover: #ff8a65;
    --red: #ff453a;
    --green: #30d158;
    --amber: #ffd60a;
    
    /* 字體 */
    --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
    --mono: 'JetBrains Mono', 'Fira Code', monospace;
    
    /* 間距基準 */
    --space-xs: 4px;
    --space-sm: 8px;
    --space-md: 16px;
    --space-lg: 24px;
    --space-xl: 48px;
    --space-2xl: 80px;
    
    --radius: 6px;
    --radius-lg: 14px;
    --max-width: 1200px;
    --nav-height: 52px;
    
    /* 全域 easing 變數 */
    --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
    --ease-in-out: cubic-bezier(0.65, 0, 0.35, 1);
  }

  [data-theme="light"] {
    --bg: #f5f5f7;
    --bg2: #ffffff;
    --bg3: #e8e8ed;
    --bg4: #d1d1d6;
    --border: #d1d1d6;
    --border-light: #b0b0b8;
    --text: #1d1d1f;
    --text2: #515154;
    --text3: #86868b;
  }

  html { scroll-behavior: smooth; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    font-size: clamp(15px, 0.93rem + 0.12vw, 16px);
    line-height: 1.6;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }
  
  .mono { font-family: var(--mono); }

  main { flex: 1; }

  a { color: var(--accent2); text-decoration: none; transition: opacity 0.2s var(--ease-out); }
  a:hover { opacity: 0.8; }

  /* Reduced motion */
  @media (prefers-reduced-motion: reduce) {
    *, *::before, *::after {
      animation-duration: 0.01ms !important;
      animation-iteration-count: 1 !important;
      transition-duration: 0.01ms !important;
      scroll-behavior: auto !important;
    }
  }

  h1, h2, h3, h4 { line-height: 1.2; font-weight: 700; }
  h1 { font-size: clamp(2rem, 5vw, 3.5rem); }
  h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); }
  h3 { font-size: clamp(1.1rem, 1rem + 0.5vw, 1.3rem); }

  p { color: var(--text2); }
  strong { color: var(--text); }

  code {
    font-family: var(--mono);
    background: var(--bg3);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.88em;
    color: var(--accent2);
  }

  pre {
    background: var(--bg3);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    font-family: var(--mono);
    font-size: 0.875rem;
    line-height: 1.6;
    position: relative;
  }

  pre code {
    background: none;
    padding: 0;
    color: #e2e8f0;
    font-size: inherit;
  }

  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    border: 1px solid var(--border-light);
    background: var(--bg2);
    color: var(--text2);
    font-size: 0.72rem;
    border-radius: 6px;
    padding: 0.2rem 0.45rem;
    cursor: pointer;
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.75rem;
    border-radius: var(--radius);
    font-weight: 600;
    font-size: 1rem;
    cursor: pointer;
    border: none;
    transition: all 0.2s var(--ease-out);
    text-decoration: none;
  }

  .btn-primary {
    background: var(--accent);
    color: white;
  }
  .btn-primary:hover { background: var(--accent-hover); opacity: 1; transform: translateY(-1px); }

  .btn-outline {
    background: transparent;
    color: var(--text);
    border: 1px solid var(--border);
  }
  .btn-outline:hover { border-color: var(--accent2); color: var(--accent2); opacity: 1; }

  .container {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .section { padding: 5rem 0; }
  .section-sm { padding: 3rem 0; }

  .badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .badge-orange { background: rgba(255,107,53,0.15); color: var(--accent); border: 1px solid rgba(255,107,53,0.3); }
  .badge-cyan { background: rgba(0,212,255,0.1); color: var(--accent2); border: 1px solid rgba(0,212,255,0.2); }

  /* FAQ */
  .faq-item { border: 1px solid var(--border); border-radius: var(--radius); overflow: hidden; margin-bottom: 0.75rem; }
  .faq-q { padding: 1rem 1.25rem; font-weight: 600; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
  .faq-q:hover { background: var(--bg3); }
  .faq-a { padding: 0 1.25rem 1rem; display: none; }
  .faq-item.open .faq-a { display: block; }
  .faq-item.open .faq-arrow { transform: rotate(180deg); }
  .faq-arrow { transition: transform 0.2s var(--ease-out); }

  /* Code hint */
  .code-hint {
    font-size: 0.78rem;
    color: var(--text2);
    margin-top: 0.25rem;
    margin-bottom: 0.75rem;
  }

  /* 手機版全局修復 */
  @media (max-width: 768px) {
    .container {
      padding-left: 1rem;
      padding-right: 1rem;
    }

    pre, code {
      font-size: 0.78rem;
      overflow-x: auto;
      white-space: pre;
      word-wrap: normal;
    }

    pre {
      padding: 0.75rem 1rem;
    }

    table {
      display: block;
      overflow-x: auto;
      white-space: nowrap;
    }

    .content-grid {
      grid-template-columns: 1fr !important;
    }
    .toc { display: none; }

    .requirements-grid,
    .why-grid,
    .provider-cards,
    .option-cards {
      grid-template-columns: 1fr !important;
    }

    .section-card,
    .skill-card,
    .model-card,
    .concept-card,
    .scenario-card,
    .free-card,
    .tip-card,
    .switch-demo,
    .clawhub-box {
      padding: 1rem !important;
    }

    .nav-buttons {
      flex-direction: column !important;
      gap: 1rem !important;
    }

    .page-hero {
      padding: 2rem 0 1.5rem !important;
    }
    .page-hero h1 {
      font-size: 1.75rem !important;
    }
    .page-subtitle {
      font-size: 1rem !important;
    }
  }
</style>

<style>
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    background: rgba(13, 13, 15, 0.92);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-weight: 800;
    font-size: 16px;
    letter-spacing: -0.03em;
    color: var(--text);
    flex-shrink: 0;
  }
  .nav-logo:hover { opacity: 0.9; }
  .logo-icon { font-size: 1.3rem; }
  .logo-subtitle {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--accent-bright);
    margin-left: -0.2rem;
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex-wrap: nowrap;
  }

  .nav-links a {
    color: var(--text2);
    font-size: 13px;
    font-weight: 500;
    padding: 4px 0;
    margin: 0 12px;
    border-bottom: 1px solid transparent;
    transition: all 0.15s var(--ease-out);
  }
  .nav-links a:hover, .nav-links a.active { 
    color: var(--text); 
    border-bottom-color: var(--text);
    opacity: 1;
  }

  .nav-kit { display: inline; }
  .nav-price {
    display: inline-block;
    background: var(--accent);
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    padding: 0.1rem 0.4rem;
    border-radius: 999px;
    margin-left: 0.3rem;
    vertical-align: middle;
  }

  .lang-switcher { margin-left: 0.5rem; }
  .lang-btn {
    padding: 0.35rem 0.85rem !important;
    border-radius: 999px !important;
    font-weight: 600 !important;
    font-size: 0.8rem !important;
  }
  .lang-en { background: rgba(0,212,255,0.1) !important; color: var(--accent2) !important; border: 1px solid rgba(0,212,255,0.3); }
  .lang-zh { background: rgba(255,107,53,0.1) !important; color: var(--accent) !important; border: 1px solid rgba(255,107,53,0.3); }

  .theme-toggle {
    background: none;
    border: 1px solid var(--border);
    color: var(--text2);
    width: 32px;
    height: 32px;
    border-radius: 6px;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 14px;
    transition: all 0.2s var(--ease-out);
    margin-left: 8px;
  }
  .theme-toggle:hover {
    border-color: var(--border-light);
    background: var(--bg2);
  }

  /* Dropdown nav */
  .nav-dropdown { position: relative; }
  .nav-dropdown-btn {
    background: none;
    border: none;
    color: var(--text2);
    font-size: 0.9rem;
    padding: 0.4rem 0.75rem;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s var(--ease-out);
    font-family: var(--font);
  }
  .nav-dropdown-btn:hover { color: var(--text); background: var(--bg3); }
  .nav-dropdown-btn.active { color: var(--text); background: var(--bg3); }
  .nav-dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 0;
    min-width: 160px;
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    z-index: 200;
    overflow: hidden;
  }
  .nav-dropdown-menu a {
    display: block;
    padding: 0.6rem 1rem;
    color: var(--text2);
    font-size: 0.9rem;
    transition: all 0.15s var(--ease-out);
  }
  .nav-dropdown-menu a:hover { background: var(--bg3); color: var(--text); opacity: 1; }
  .nav-dropdown.open .nav-dropdown-menu { display: block; }
  .nav-dropdown.open .nav-dropdown-btn { color: var(--text); background: var(--bg3); }

  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }
  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text);
    border-radius: 2px;
    transition: all 0.3s;
  }

  .footer {
    background: var(--bg2);
    border-top: 1px solid var(--border);
    padding: 3rem 0 2rem;
    margin-top: auto;
  }

  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1.5rem;
    text-align: center;
  }

  .footer-brand {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-weight: 700;
    font-size: 1.1rem;
    margin-bottom: 0.75rem;
  }

  .footer-desc { margin-bottom: 1.25rem; font-size: 0.9rem; }

  .footer-links {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
    font-size: 0.9rem;
  }

  .footer-copy { font-size: 0.8rem; color: #555; }

  @media (max-width: 768px) {
    :root { --nav-height: 56px; }
    .hamburger { display: flex; }
    .nav-inner { padding: 0 1rem; }
    .logo-subtitle { display: none; }
    .nav-links {
      display: none;
      position: absolute;
      top: var(--nav-height);
      left: 0;
      right: 0;
      background: var(--bg2);
      border-bottom: 1px solid var(--border);
      flex-direction: column;
      padding: 0.8rem 1rem 1rem;
      gap: 0.2rem;
      align-items: stretch;
    }
    .nav-links a {
      margin: 0;
      width: 100%;
      padding: 0.6rem 0.15rem;
      border-bottom: 0;
      border-radius: 6px;
    }
    .nav-links a:hover, .nav-links a.active {
      background: var(--bg3);
      border-bottom-color: transparent;
    }
    .nav-links.open { display: flex; }
    .lang-switcher { margin-left: 0; margin-top: 0.35rem; }

    /* Mobile dropdown: always expanded in mobile menu */
    .nav-dropdown { width: 100%; }
    .nav-dropdown-btn { padding-left: 0; }
    .nav-dropdown-menu {
      display: block;
      position: static;
      box-shadow: none;
      border: none;
      background: transparent;
      padding-left: 0.75rem;
      min-width: auto;
      border-left: 2px solid var(--border);
      margin: 0.25rem 0;
    }
