---
export interface Props {
  title: string;
  description?: string;
  lang?: string;
  currentPath?: string;
  ogImage?: string;
}

const { title, description = "AI 產業地圖與量化交易指南", lang = "zh", currentPath = "/", ogImage = "https://openclaw-guide-red.vercel.app/og-image.png" } = Astro.props;
---

<!DOCTYPE html>
<html lang={lang} data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} — MiniBot Terminal</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700;800&family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
  </head>
  <body>
    <nav class="nav">
      <div class="nav-inner">
        <a href="/" class="nav-logo">
          <span class="logo-icon">MINIBOT</span>
          <span class="logo-subtitle">SYS_TERMINAL_V1</span>
        </a>
        <div class="nav-links mono">
          <a href="/" class={currentPath === '/' ? 'active' : ''}>[DASHBOARD]</a>
          <a href="/industry" class={currentPath.includes('/industry') ? 'active' : ''}>[INDUSTRY]</a>
          <a href="/news" class={currentPath.includes('/news') ? 'active' : ''}>[MARKET_NEWS]</a>
          <a href="/guide/install" class={currentPath.includes('/guide') ? 'active' : ''}>[SYSTEM_DOCS]</a>
        </div>
        <div class="nav-status mono">
          <span class="pulse-dot"></span> <span class="text-green">CONN_OK</span>
        </div>
      </div>
    </nav>

    <main class="terminal-main">
      <slot />
    </main>

    <footer class="footer mono">
      <div class="footer-inner">
        <span>© 2026 MINIBOT TERMINAL. DATA DELAYED 15 MIN.</span>
        <span>SYS_STATUS: OPTIMAL</span>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #000000;
    --bg2: #0a0a0a;
    --bg3: #141414;
    --border: #333333;
    --border-light: #555555;
    
    --text: #eaeaea;
    --text2: #8a8a8a;
    
    --accent: #ff8c00;      /* Bloomberg Orange/Amber */
    --accent-hover: #ffaa33;
    --accent2: #00ff00;     /* Terminal Green */
    --red: #ff3333;         /* Down Red */
    --green: #00ff00;       /* Up Green */
    
    --font: 'Inter', sans-serif;
    --mono: 'JetBrains Mono', monospace;
    
    --max-width: 1400px;
    --nav-height: 48px;
  }

  html { background: var(--bg); }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font);
    font-size: 14px;
    line-height: 1.5;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    -webkit-font-smoothing: antialiased;
  }
  
  .mono { font-family: var(--mono); }
  .text-green { color: var(--green); }
  .text-red { color: var(--red); }
  .text-orange { color: var(--accent); }

  main { flex: 1; }
  a { color: var(--accent); text-decoration: none; }
  a:hover { color: var(--text); }

  /* Nav */
  .nav {
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
    background: var(--bg);
    border-bottom: 2px solid var(--border);
  }

  .nav-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0 1rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    display: flex;
    gap: 0.75rem;
    font-family: var(--mono);
    font-weight: 800;
    color: var(--accent);
  }

  .logo-subtitle { color: var(--text2); font-weight: 400; }

  .nav-links {
    display: flex;
    gap: 1.5rem;
  }

  .nav-links a {
    color: var(--text2);
    font-size: 13px;
    font-weight: 700;
  }
  .nav-links a.active { color: var(--accent2); }
  .nav-links a:hover { color: var(--text); }

  .nav-status {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 12px;
  }
  .pulse-dot {
    width: 8px;
    height: 8px;
    background: var(--green);
    border-radius: 50%;
    animation: flash 1s infinite;
  }
  @keyframes flash {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  .footer {
    border-top: 1px solid var(--border);
    padding: 1rem;
    font-size: 11px;
    color: var(--text2);
  }
  .footer-inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
  }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .logo-subtitle { display: none; }
  }
</style>
