<div id="terminal-shell" class="terminal-shell" aria-hidden="true">
  <div class="terminal-handle">
    <span class="dot green"></span>
    <span class="dot yellow"></span>
    <span class="dot red"></span>
    <span class="terminal-title">minibot://ghost-console</span>
    <span class="terminal-hint">Press ~ to toggle</span>
  </div>

  <div id="terminal-output" class="terminal-output" aria-live="polite"></div>

  <form id="terminal-form" class="terminal-input-row" autocomplete="off">
    <span class="prompt">guest@minibot:~$</span>
    <input id="terminal-input" type="text" spellcheck="false" placeholder="type help" />
  </form>
</div>

<style>
  .terminal-shell {
    position: fixed;
    left: 50%;
    bottom: 0;
    transform: translate(-50%, calc(100% + 12px));
    width: min(980px, calc(100vw - 1.25rem));
    height: min(56vh, 460px);
    border: 1px solid rgba(16, 185, 129, 0.24);
    border-bottom: none;
    border-top-left-radius: 14px;
    border-top-right-radius: 14px;
    background: linear-gradient(180deg, rgba(3, 10, 8, 0.98) 0%, rgba(4, 7, 6, 0.98) 100%);
    box-shadow: 0 -16px 48px rgba(0,0,0,0.65), 0 0 0 1px rgba(16, 185, 129, 0.08) inset;
    z-index: 120;
    display: flex;
    flex-direction: column;
    opacity: 0;
    transition: transform 0.28s cubic-bezier(.2,.8,.2,1), opacity 0.2s ease;
    pointer-events: none;
  }

  .terminal-shell.open {
    transform: translate(-50%, 0);
    opacity: 1;
    pointer-events: auto;
  }

  .terminal-handle {
    min-height: 40px;
    display: flex;
    align-items: center;
    gap: 0.45rem;
    padding: 0.5rem 0.8rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
    background: rgba(255,255,255,0.02);
    font-family: var(--font-mono);
  }

  .dot { width: 9px; height: 9px; border-radius: 999px; display: inline-flex; }
  .dot.green { background: #22c55e; }
  .dot.yellow { background: #eab308; }
  .dot.red { background: #ef4444; }
  .terminal-title { color: #93c5fd; font-size: 0.72rem; margin-left: 0.4rem; }
  .terminal-hint { margin-left: auto; font-size: 0.68rem; color: #6b7280; }

  .terminal-output {
    flex: 1;
    overflow-y: auto;
    padding: 0.75rem 0.9rem;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    line-height: 1.5;
    color: #86efac;
  }

  .line { white-space: pre-wrap; word-break: break-word; }
  .line.muted { color: #6b7280; }
  .line.error { color: #fca5a5; }
  .line.info { color: #93c5fd; }

  .terminal-input-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    border-top: 1px solid rgba(255,255,255,0.07);
    padding: 0.65rem 0.9rem 0.8rem;
    background: rgba(0,0,0,0.2);
    font-family: var(--font-mono);
  }

  .prompt { color: #4ade80; font-size: 0.78rem; white-space: nowrap; }

  #terminal-input {
    flex: 1;
    border: none;
    background: transparent;
    color: #e5e7eb;
    font-family: var(--font-mono);
    font-size: 0.82rem;
    outline: none;
  }

  #terminal-input::placeholder { color: #4b5563; }

  @media (max-width: 768px) {
    .terminal-shell { height: min(62vh, 500px); }
    .terminal-hint { display: none; }
  }
</style>

<script>
  const shell = document.getElementById('terminal-shell');
  const output = document.getElementById('terminal-output');
  const form = document.getElementById('terminal-form');
  const input = document.getElementById('terminal-input');

  if (shell && output && form && input) {
    const state = { open: false, printing: false };

    const commandMap = {
      help: [
        '[commands]',
        'help              show available commands',
        'minibot status    inspect all systems',
        'ping openai       test uplink latency',
        'clear             clear terminal output'
      ],
      'minibot status': [
        '↳ node: online',
        '↳ orchestrator: healthy',
        '↳ memory bus: synchronized',
        '↳ model gateway: active'
      ],
      'ping openai': [
        'Pinging openai gateway...',
        '64 bytes from api.openai.com: icmp_seq=1 ttl=57 time=22.4 ms',
        '64 bytes from api.openai.com: icmp_seq=2 ttl=57 time=18.8 ms',
        '64 bytes from api.openai.com: icmp_seq=3 ttl=57 time=19.7 ms',
        '--- openai ping statistics ---',
        '3 packets transmitted, 3 received, 0% packet loss'
      ]
    };

    const sleep = (ms) => new Promise((r) => setTimeout(r, ms));

    const appendLine = (text, cls = '') => {
      const el = document.createElement('div');
      el.className = `line ${cls}`.trim();
      el.textContent = text;
      output.appendChild(el);
      output.scrollTop = output.scrollHeight;
      return el;
    };

    const typeLine = async (text, cls = 'info', speed = 12) => {
      const el = appendLine('', cls);
      for (let i = 0; i < text.length; i += 1) {
        el.textContent += text[i];
        output.scrollTop = output.scrollHeight;
        await sleep(speed);
      }
    };

    const printBanner = async () => {
      if (output.childElementCount > 0) return;
      await typeLine('MiniBot stealth terminal initialized', 'info', 10);
      await typeLine('Type `help` to see available commands.', 'muted', 8);
    };

    const openTerminal = async () => {
      state.open = true;
      shell.classList.add('open');
      shell.setAttribute('aria-hidden', 'false');
      await printBanner();
      input.focus();
    };

    const closeTerminal = () => {
      state.open = false;
      shell.classList.remove('open');
      shell.setAttribute('aria-hidden', 'true');
    };

    const executeCommand = async (raw) => {
      const cmd = raw.trim();
      if (!cmd) return;

      appendLine(`guest@minibot:~$ ${cmd}`, 'muted');

      if (cmd === 'clear') {
        output.innerHTML = '';
        return;
      }

      const response = commandMap[cmd];
      if (!response) {
        await typeLine(`command not found: ${cmd}`, 'error', 9);
        await typeLine("try `help`", 'muted', 9);
        return;
      }

      state.printing = true;
      for (const line of response) {
        await typeLine(line, 'info', 10);
      }
      state.printing = false;
    };

    document.addEventListener('keydown', (e) => {
      const isTilde = e.key === '~' || e.code === 'Backquote';
      if (!isTilde || e.metaKey || e.ctrlKey || e.altKey) return;

      const active = document.activeElement;
      const typingElsewhere = active && ['INPUT', 'TEXTAREA'].includes(active.tagName) && active !== input;
      if (typingElsewhere) return;

      e.preventDefault();
      if (state.open) closeTerminal();
      else openTerminal();
    });

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      if (state.printing) return;
      const value = input.value;
      input.value = '';
      await executeCommand(value);
      input.focus();
    });
  }
</script>