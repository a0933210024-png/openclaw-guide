---
const tiles = [
  { label: 'AGI', score: 0.88, size: 'xl' },
  { label: 'OpenAI', score: 0.72, size: 'lg' },
  { label: 'Nvidia Blackwell', score: 0.64, size: 'lg' },
  { label: 'EU Regulation', score: -0.52, size: 'md' },
  { label: 'Inference Cost', score: -0.26, size: 'md' },
  { label: 'Agent Infra', score: 0.49, size: 'md' },
  { label: 'Datacenter CAPEX', score: 0.35, size: 'sm' },
  { label: 'Open Source MoE', score: 0.41, size: 'sm' },
  { label: 'Copyright Lawsuit', score: -0.44, size: 'sm' },
  { label: 'AI Safety Labs', score: 0.17, size: 'sm' },
  { label: 'Chip Supply Chain', score: -0.11, size: 'sm' },
  { label: 'Enterprise Agents', score: 0.56, size: 'md' }
];

const tone = (score: number) => {
  const intensity = Math.min(0.88, Math.max(0.18, Math.abs(score)));
  if (score >= 0) {
    return {
      bg: `rgba(34,197,94,${intensity})`,
      border: `rgba(74,222,128,${Math.min(0.95, intensity + 0.25)})`
    };
  }
  return {
    bg: `rgba(239,68,68,${intensity})`,
    border: `rgba(252,165,165,${Math.min(0.95, intensity + 0.25)})`
  };
};
---

<section class="heatmap-card">
  <div class="heatmap-head">
    <h3>Market Sentiment Heatmap</h3>
    <span>live posture snapshot · default synthetic alpha</span>
  </div>

  <div class="heatmap-grid">
    {tiles.map((tile) => {
      const c = tone(tile.score);
      return (
        <article class={`tile ${tile.size}`} style={`--tile-bg:${c.bg}; --tile-border:${c.border};`}>
          <p class="label">{tile.label}</p>
          <p class="score">{tile.score > 0 ? '+' : ''}{(tile.score * 100).toFixed(0)}%</p>
        </article>
      );
    })}
  </div>
</section>

<style>
  .heatmap-card {
    margin: 1.8rem 0 2.2rem;
    padding: 1rem;
    border-radius: 16px;
    border: 1px solid rgba(255,255,255,0.08);
    background: radial-gradient(120% 140% at 10% 10%, rgba(56,189,248,0.08), rgba(12,12,12,0.92));
  }

  .heatmap-head { display: flex; justify-content: space-between; gap: 1rem; align-items: baseline; margin-bottom: 0.9rem; }
  .heatmap-head h3 { font-size: 1.05rem; letter-spacing: -0.01em; }
  .heatmap-head span { font-size: 0.72rem; color: #6b7280; text-transform: uppercase; letter-spacing: 0.08em; }

  .heatmap-grid {
    display: grid;
    grid-template-columns: repeat(8, minmax(0, 1fr));
    grid-auto-rows: 56px;
    gap: 0.55rem;
  }

  .tile {
    border: 1px solid var(--tile-border);
    border-radius: 10px;
    background: linear-gradient(160deg, var(--tile-bg), rgba(0,0,0,0.18));
    padding: 0.65rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03);
    animation: pulse 2.4s ease-in-out infinite;
  }

  .tile.xl { grid-column: span 3; grid-row: span 2; }
  .tile.lg { grid-column: span 2; grid-row: span 2; }
  .tile.md { grid-column: span 2; grid-row: span 1; }
  .tile.sm { grid-column: span 1; grid-row: span 1; }

  .label { font-size: 0.8rem; color: #e5e7eb; font-weight: 600; }
  .score { font-family: var(--font-mono); font-size: 0.82rem; color: #f9fafb; opacity: 0.95; }

  @keyframes pulse {
    0%, 100% { filter: saturate(1) brightness(1); }
    50% { filter: saturate(1.08) brightness(1.06); }
  }

  @media (max-width: 920px) {
    .heatmap-grid { grid-template-columns: repeat(4, minmax(0, 1fr)); grid-auto-rows: 52px; }
    .tile.xl, .tile.lg { grid-column: span 2; }
    .tile.md { grid-column: span 2; }
    .tile.sm { grid-column: span 1; }
  }

  @media (max-width: 560px) {
    .heatmap-head { flex-direction: column; }
  }
</style>