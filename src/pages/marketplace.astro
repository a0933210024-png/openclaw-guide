---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Claw Mart — Ready-Made AI Personas" lang="en" currentPath="/marketplace" description="Buy pre-configured OpenClaw personas. Skip the setup and start using your AI assistant in 30 minutes.">
  <div class="page-hero">
    <div class="container">
      <span class="badge badge-orange">🛒 Claw Mart</span>
      <h1>Ready-Made AI Personas</h1>
      <p class="page-subtitle">
        Skip hours of configuration. Buy a pre-built persona pack, drop it into your OpenClaw workspace, and you're live in under 30 minutes.
        Expert setups, tested configurations, ready to use.
      </p>
      <div class="hero-cta">
        <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
          🛒 Shop on Claw Mart
        </a>
        <div class="lang-notice">
          <a href="/zh/marketplace">🇹🇼 閱讀中文版</a>
        </div>
      </div>
    </div>
  </div>

  <!-- Value Prop -->
  <section class="section value-section">
    <div class="container">
      <div class="value-grid">
        <div class="value-card">
          <div class="value-icon">⏱️</div>
          <h3>Save Hours of Setup</h3>
          <p>A well-crafted SOUL.md + integration config takes 4–8 hours to get right. Our personas are pre-tested and ready to use immediately.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">🧠</div>
          <h3>Expert-Crafted Prompts</h3>
          <p>Each persona is fine-tuned with behavioral instructions, example interactions, and edge-case handling that only comes from real experience.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">🔧</div>
          <h3>Plug & Play</h3>
          <p>Drop the files into your <code>~/.openclaw/workspace/</code> folder, restart the gateway, and your persona is live. No coding required.</p>
        </div>
        <div class="value-card">
          <div class="value-icon">♾️</div>
          <h3>Yours Forever</h3>
          <p>One-time purchase. No subscriptions, no usage limits. The persona files are yours — customize them however you like.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Newly Listed Section -->
  <section class="section new-listed-section">
    <div class="container">
      <h2>最新上架</h2>
      <p>最近新增的 AI Personas，搶先體驗新功能！</p>
      <div class="products-grid">
        <!-- Example New Product -->
        <div class="product-card">
          <div class="product-icon">🆕</div>
          <h3>New Persona 1</h3>
          <div class="product-price">$25</div>
          <p class="product-desc">Description of new persona.</p>
          <a href="#" class="btn btn-outline product-btn">View Details</a>
        </div>
        <!-- Add more as needed -->
      </div>
    </div>
  </section>

  <!-- This Week's Picks Section -->
  <section class="section picks-section">
    <div class="container">
      <h2>本週精選</h2>
      <p>我們推薦的本週最佳 Personas。</p>
      <div class="products-grid">
        <!-- Example Pick Product -->
        <div class="product-card featured">
          <div class="product-icon">⭐</div>
          <h3>Featured Pick</h3>
          <div class="product-price">$30</div>
          <p class="product-desc">Description of featured persona.</p>
          <a href="#" class="btn btn-primary product-btn">Buy Now</a>
        </div>
        <!-- Add more as needed -->
      </div>
    </div>
  </section>

  <!-- Category Filter UI -->
  <section class="section filter-section">
    <div class="container">
      <h2>分類篩選</h2>
      <div class="filter-ui">
        <select class="filter-select">
          <option value="">All Categories</option>
          <option value="productivity">Productivity</option>
          <option value="research">Research</option>
          <option value="development">Development</option>
          <option value="support">Customer Support</option>
        </select>
        <input type="text" placeholder="Search personas..." class="filter-search" />
        <button class="filter-button">Apply Filter</button>
      </div>
    </div>
  </section>

  <!-- Products -->
  <section class="section products-section">
    <div class="container">
      <div class="section-header">
        <span class="badge badge-cyan">Hot Picks</span>
        <h2>Most Popular Personas</h2>
        <p>Hand-crafted for real use cases. Every pack comes with a SOUL.md, integration guide, and 30-day support.</p>
      </div>

      <div class="products-grid">
        <!-- Trading Pack -->
        <div class="product-card featured">
          <div class="product-badge">🔥 Best Seller</div>
          <div class="product-icon">📊</div>
          <h3>BlackPink Trading Team Pack</h3>
          <div class="product-price">$39</div>
          <p class="product-desc">Four specialized AI personas that work together as a Hydra trading team: Rosé (quant manager), Lisa (technical analyst), Jisoo (news intel), Jennie (risk assessment). Paper trading setup included.</p>
          <ul class="product-features">
            <li>4 pre-built personas with distinct personalities</li>
            <li>Hydra coordination protocol scripts</li>
            <li>Paper trading simulator integration</li>
            <li>Telegram notification templates</li>
            <li>30-day support</li>
          </ul>
          <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-primary product-btn">Buy for $39 →</a>
        </div>

        <!-- Productivity -->
        <div class="product-card">
          <div class="product-icon">🤖</div>
          <h3>Aria — Productivity Assistant</h3>
          <div class="product-price">$19</div>
          <p class="product-desc">Your personal AI chief of staff. Morning briefings, email triage, calendar management, and smart reminders. Configured for Gmail + Google Calendar out of the box.</p>
          <ul class="product-features">
            <li>Morning briefing automation (7 AM cron)</li>
            <li>Gmail + Google Calendar integration</li>
            <li>Email draft templates (20+ scenarios)</li>
            <li>Reminder system with context memory</li>
            <li>30-day support</li>
          </ul>
          <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-outline product-btn">Buy for $19 →</a>
        </div>

        <!-- Research Assistant -->
        <div class="product-card">
          <div class="product-icon">🔬</div>
          <h3>Nova — Research Assistant</h3>
          <div class="product-price">$19</div>
          <p class="product-desc">Deep research persona for academics, journalists, and analysts. Summarizes papers, extracts key insights, tracks sources, and generates structured reports.</p>
          <ul class="product-features">
            <li>Academic paper summarization</li>
            <li>Source tracking & citation formatting</li>
            <li>Report generation templates</li>
            <li>Web search integration</li>
            <li>30-day support</li>
          </ul>
          <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-outline product-btn">Buy for $19 →</a>
        </div>

        <!-- Developer -->
        <div class="product-card">
          <div class="product-icon">💻</div>
          <h3>Dev Buddy — Code Review Bot</h3>
          <div class="product-price">$29</div>
          <p class="product-desc">Your personal code reviewer and pair programmer. Paste code snippets in Telegram and get structured reviews, bug detection, and refactoring suggestions.</p>
          <ul class="product-features">
            <li>Multi-language code review (10+ languages)</li>
            <li>Security vulnerability scanning prompts</li>
            <li>PR summary generation</li>
            <li>GitHub webhook integration</li>
            <li>30-day support</li>
          </ul>
          <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-outline product-btn">Buy for $29 →</a>
        </div>

        <!-- Customer Support -->
        <div class="product-card">
          <div class="product-icon">💬</div>
          <h3>Scout — Customer Support Bot</h3>
          <div class="product-price">$29</div>
          <p class="product-desc">Deploy a polite, professional customer-facing chatbot on Telegram or WhatsApp. Handles FAQs, escalates edge cases, and logs conversations.</p>
          <ul class="product-features">
            <li>Configurable FAQ knowledge base</li>
            <li>Human escalation triggers</li>
            <li>Conversation logging & export</li>
            <li>Multi-language support (10 languages)</li>
            <li>30-day support</li>
          </ul>
          <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-outline product-btn">Buy for $29 →</a>
        </div>

        <!-- Starter Bundle -->
        <div class="product-card bundle">
          <div class="product-badge">💰 Best Value</div>
          <div class="product-icon">🎁</div>
          <h3>Starter Bundle</h3>
          <div class="product-price">$49 <span class="original-price">$96</span></div>
          <p class="product-desc">Get Aria (Productivity) + Nova (Research) + Dev Buddy — the three personas most people start with. Plus the Starter Kit PDF and onboarding call.</p>
          <ul class="product-features">
            <li>3 persona packs (Aria + Nova + Dev Buddy)</li>
            <li>Starter Kit PDF guide</li>
            <li>1-hour onboarding session</li>
            <li>60-day priority support</li>
          </ul>
          <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-primary product-btn">Buy Bundle for $49 →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section faq-section">
    <div class="container">
      <div class="section-header">
        <h2>Frequently Asked Questions</h2>
      </div>
      <div class="faq-list">
        <div class="faq-item">
          <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
            Do I need OpenClaw installed first?
            <span class="faq-arrow">▼</span>
          </div>
          <div class="faq-a">
            <p>Yes — Claw Mart personas require OpenClaw to run. If you haven't installed it yet, start with our <a href="/guide/install">installation guide</a>. It takes about 5 minutes.</p>
          </div>
        </div>
        <div class="faq-item">
          <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
            Can I customize the personas after buying?
            <span class="faq-arrow">▼</span>
          </div>
          <div class="faq-a">
            <p>Absolutely. All personas are plain text files (SOUL.md and config files). Edit them to match your name, preferences, and use case. They're a starting point, not a black box.</p>
          </div>
        </div>
        <div class="faq-item">
          <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
            What AI model do I need for these personas?
            <span class="faq-arrow">▼</span>
          </div>
          <div class="faq-a">
            <p>Most personas are tested with Claude 3.5 Sonnet (Anthropic) and GPT-4o (OpenAI). They work with other models too, but performance is best with Claude. You'll need your own API key.</p>
          </div>
        </div>
        <div class="faq-item">
          <div class="faq-q" onclick="this.parentElement.classList.toggle('open')">
            Is there a refund policy?
            <span class="faq-arrow">▼</span>
          </div>
          <div class="faq-a">
            <p>Yes — 7-day money-back guarantee if the persona doesn't work as described, no questions asked. Contact support via the Claw Mart website.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="section cta-final">
    <div class="container">
      <div class="cta-inner">
        <h2>Ready to Upgrade Your AI Setup?</h2>
        <p>Join hundreds of OpenClaw users who skipped the configuration headache and went straight to productivity.</p>
        <a href="https://shopclawmart.com" target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-lg">
          🛒 Shop Claw Mart Now →
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Existing styles */

  /* New styles for added sections */
  .new-listed-section, .picks-section, .filter-section { padding: 3rem 0; border-bottom: 1px solid var(--border); }
  .filter-ui { display: flex; gap: 1rem; justify-content: center; margin-top: 1rem; }
  .filter-select, .filter-search { padding: 0.5rem 1rem; border: 1px solid var(--border); border-radius: var(--radius); }
  .filter-button { background: var(--accent); color: white; border: none; padding: 0.5rem 1rem; border-radius: var(--radius); cursor: pointer; }
</style>
