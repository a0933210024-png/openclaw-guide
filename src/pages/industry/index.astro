  { id: "soun", name: "SoundHound AI", ticker: "SOUN", sector: "AI 應用", sectorEn: "AI Applications", desc: "語音 AI 對話平台，餐廳點餐到汽車語音助理都在做", descEn: "Voice AI platform powering restaurant ordering and in-car assistants", url: "https://soundhound.com", listed: true, domain: "soundhound.com" },
  { id: "snow", name: "Snowflake", ticker: "SNOW", sector: "AI 應用", sectorEn: "AI Applications", desc: "雲端數據倉儲平台，Cortex AI 讓非技術用戶也能用 AI 分析數據", descEn: "Cloud data warehouse with Cortex AI for non-technical data analysis", url: "https://snowflake.com", listed: true, domain: "snowflake.com" },
  { id: "scaleai", name: "Scale AI", ticker: null, sector: "AI 應用", sectorEn: "AI Applications", desc: "AI 訓練數據標註龍頭，美國軍方最大 AI 數據供應商", descEn: "Leading AI training data labeling company, top Pentagon AI data supplier", url: "https://scale.com", listed: false, valuation: "$14B", fundingStage: "私人公司", domain: "scale.com" },

  // 機器人/自動駕駛
  { id: "tsla", name: "Tesla", ticker: "TSLA", sector: "機器人/自動駕駛", sectorEn: "Robotics & Auto", desc: "FSD 自動駕駛 + Optimus 人形機器人，AI 硬體的下一個前線", descEn: "FSD autonomous driving + Optimus humanoid robot, next AI hardware frontier", url: "https://tesla.com", listed: true, domain: "tesla.com" },
  { id: "aapl", name: "Apple", ticker: "AAPL", sector: "AI 應用", sectorEn: "AI Applications", desc: "Apple Intelligence 端側 AI，裝置內執行保護隱私，整合 ChatGPT", descEn: "On-device AI with Apple Intelligence, privacy-first approach, ChatGPT integration", url: "https://apple.com", listed: true, domain: "apple.com" },
];

const listedCompanies = AI_COMPANIES.filter(c => c.listed);
const privateCompanies = AI_COMPANIES.filter(c => !c.listed);
---

<Layout 
  title="AI 產業全景 — MiniBot" 
  lang="zh" 
  currentPath="/industry" 
  description="從晶片到應用，掌握整個 AI 價值鍊。追蹤 34 家核心 AI 公司的最新動態與股價資訊。"
>
  <!-- Page Header - Editorial Style -->
  <section class="page-header">
    <div class="container">
      <h1>🔭 AI 產業全景</h1>
      <p>從晶片到應用，掌握整個 AI 價值鍊</p>
    </div>
  </section>

  <!-- Filter Bar -->
  <section class="filter-bar">
    <button class="filter-tab active" data-filter="all">全部</button>
    <button class="filter-tab" data-filter="晶片/硬體">晶片/硬體</button>
    <button class="filter-tab" data-filter="基礎模型">基礎模型</button>
    <button class="filter-tab" data-filter="雲端基礎設施">雲端基礎設施</button>
    <button class="filter-tab" data-filter="AI 應用">AI 應用</button>
    <button class="filter-tab" data-filter="機器人/自動駕駛">機器人</button>
  </section>

  <!-- Companies Grid -->
  <section class="companies-section">
    <div class="companies-grid" id="companies-grid">
      {AI_COMPANIES.map((company) => (
        <div class="company-card" data-sector={company.sector}>
          <div class="company-header">
            <div class="company-logo" data-domain={company.domain} data-abbr={company.name.substring(0, 2).toUpperCase()} data-bg="#2a2a30">
              {company.name.substring(0, 2).toUpperCase()}
            </div>
            <div>
              <div class="company-name">{company.name}</div>
              {company.listed ? (
                <div class="company-ticker mono">${company.ticker}</div>
              ) : (
                <div class="company-ticker mono">{company.fundingStage}</div>
              )}
            </div>
          </div>
          
          <div class="company-sector">{company.sector}</div>
          
          <p class="company-desc">{company.desc}</p>
          
          {company.listed ? (
            <div class="company-stats">
              <div class="stat-col">
                <div class="stat-label-sm">股價</div>
                <div class="stat-val mono" data-ticker={company.ticker} data-type="price">--</div>
              </div>
              <div class="stat-col">
                <div class="stat-label-sm">市值</div>
                <div class="stat-val mono" data-ticker={company.ticker} data-type="marketcap">--</div>
              </div>
              <div class="stat-col">
                <div class="stat-label-sm">YTD</div>
                <div class="stat-val mono" data-ticker={company.ticker} data-type="ytd">--</div>
              </div>
            </div>
          ) : (
            <div class="company-stats">
              <div class="stat-col">
                <div class="stat-label-sm">估值</div>
                <div class="stat-val mono">{company.valuation}</div>
              </div>
              <div class="stat-col">
                <div class="stat-label-sm">狀態</div>
                <div class="stat-val" style="font-size: 12px;">私人</div>
              </div>
            </div>
          )}
          
          <a href={company.url} target="_blank" rel="noopener noreferrer" class="company-link">
            了解更多 →
          </a>
        </div>
      ))}
    </div>
  </section>

  <!-- Bottom Stats -->
  <section class="bottom-stats">
    <div class="container">
      <div class="stats-row">
        <div class="stat-box">
          <span class="stat-num mono">{listedCompanies.length}</span>
          <span class="stat-text">追蹤上市公司</span>
        </div>
        <div class="stat-box">
          <span class="stat-num mono">{privateCompanies.length}</span>
          <span class="stat-text">追蹤私人公司</span>
        </div>
        <div class="stat-box">
          <span class="stat-num mono">每日</span>
          <span class="stat-text">資料更新（美東 4PM 收盤後）</span>
        </div>
      </div>
    </div>
  </section>

  <script is:inline define:vars={{ AI_COMPANIES }}>
    // Multi-layer logo fallback: Clearbit → Google Favicon → Initials
    function loadCompanyLogo(img, domain, abbr, bgColor) {
      const clearbitUrl = `https://logo.clearbit.com/${domain}`;
      const googleUrl = `https://www.google.com/s2/favicons?domain=${domain}&sz=64`;
      
      img.onerror = function() {
        // Clearbit 失敗 → 試 Google Favicon
        if (this.src !== googleUrl) {
          this.src = googleUrl;
        } else {
          // Google 也失敗 → 顯示首字母 fallback
          const parent = this.closest('.company-logo');
          if (parent) {
            this.remove();
            parent.style.background = bgColor || '#2a2a30';
            parent.textContent = abbr;
          }
        }
      };
      
      img.src = clearbitUrl;
    }

    // 初始化所有 logo
    document.querySelectorAll('.company-logo[data-domain]').forEach(logoEl => {
      const domain = logoEl.getAttribute('data-domain');
      const abbr = logoEl.getAttribute('data-abbr');
      const bg = logoEl.getAttribute('data-bg');
      const img = document.createElement('img');
      img.alt = domain;
      img.style.cssText = 'width:100%;height:100%;object-fit:contain;';
      logoEl.innerHTML = '';
      logoEl.appendChild(img);
      loadCompanyLogo(img, domain, abbr, bg);
    });

    // Load stock data
    async function loadStockData() {
      try {
        const res = await fetch('/stocks.json');
        if (!res.ok) return;
        
        const data = await res.json();
        
        // Update all stock-related elements
        document.querySelectorAll('[data-ticker]').forEach(el => {
          const ticker = el.getAttribute('data-ticker');
          const type = el.getAttribute('data-type');
          const stockData = data.stocks[ticker];
          
          if (!stockData) return;
          
          if (type === 'price' && stockData.price > 0) {
            el.textContent = `$${stockData.price.toFixed(2)}`;
          } else if (type === 'marketcap' && stockData.marketCapB > 0) {
            el.textContent = `$${stockData.marketCapB.toFixed(0)}B`;
          } else if (type === 'ytd' && stockData.ytdPct !== 0) {
            const pct = stockData.ytdPct;
            el.textContent = `${pct > 0 ? '+' : ''}${pct.toFixed(1)}%`;
            el.classList.add(pct > 0 ? 'up' : 'down');
          }
        });
      } catch (error) {
        console.error('Failed to load stock data:', error);
      }
    }
    
    // Filter functionality
    const filterTabs = document.querySelectorAll('.filter-tab');
    const companyCards = document.querySelectorAll('.company-card');
    
    filterTabs.forEach(tab => {
      tab.addEventListener('click', () => {
        filterTabs.forEach(t => t.classList.remove('active'));
        tab.classList.add('active');
        
        const filter = tab.getAttribute('data-filter');
        
        companyCards.forEach(card => {
          if (filter === 'all' || card.getAttribute('data-sector') === filter) {
            card.style.display = 'block';
          } else {
            card.style.display = 'none';
          }
        });
      });
    });
    
    loadStockData();
  </script>

  <style>
    /* Page Header - Editorial */
    .page-header {
      padding: 48px 0 32px;
      border-bottom: 1px solid var(--border);
    }

    .page-header h1 {
      font-size: 36px;
      font-weight: 700;
      letter-spacing: -0.03em;
      margin: 0 0 8px;
    }

    .page-header p {
      color: var(--text2);
      font-size: 16px;
      margin: 0;
    }

    /* Filter Bar */
    .filter-bar {
      display: flex;
      gap: 0;
      border-bottom: 1px solid var(--border);
      overflow-x: auto;
    }

    .filter-tab {
      padding: 12px 20px;
      font-size: 13px;
      font-weight: 600;
      color: var(--text2);
      background: none;
      border: none;
      border-bottom: 2px solid transparent;
      cursor: pointer;
      transition: all 0.15s var(--ease-out);
      white-space: nowrap;
      font-family: var(--font);
    }

    .filter-tab:hover {
      color: var(--text);
    }

    .filter-tab.active {
      color: var(--accent-bright);
      border-bottom-color: var(--accent-bright);
    }

    /* Companies Grid */
    .companies-section {
      padding: 0;
    }

    .companies-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
      gap: 1px;
      background: var(--border);
    }

    .company-card {
      background: var(--bg);
      padding: clamp(0.85rem, 1.6vw, 1.5rem);
      transition: background 0.15s var(--ease-out);
      display: flex;
      flex-direction: column;
    }

    .company-card:hover {
      background: var(--bg2);
    }

    .company-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 16px;
    }

    .company-logo {
      width: 36px;
      height: 36px;
      border-radius: 6px;
      overflow: hidden;
      background: var(--bg3);
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 13px;
      font-weight: 700;
      color: var(--text2);
      flex-shrink: 0;
    }

    .company-logo img {
      width: 100%;
      height: 100%;
      object-fit: contain;
    }

    .company-name {
      font-size: 15px;
      font-weight: 700;
      color: var(--text);
    }

    .company-ticker {
      font-size: 11px;
      color: var(--text3);
      font-weight: 500;
    }

    .company-sector {
      display: inline-block;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      color: var(--text3);
      background: var(--bg4);
      padding: 2px 8px;
      border-radius: 2px;
      margin-bottom: 12px;
    }

    .company-desc {
      font-size: 13px;
      line-height: 1.55;
      color: var(--text2);
      margin: 0 0 16px;
      flex-grow: 1;
    }

    .company-stats {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      border-top: 1px solid var(--border);
      padding-top: 12px;
      margin-top: auto;
      gap: 8px;
      margin-bottom: 12px;
    }

    .stat-col {
      padding: 0;
    }

    .stat-label-sm {
      font-size: 10px;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--text3);
      margin-bottom: 2px;
    }

    .stat-val {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
    }

    .stat-val.up {
      color: var(--green);
    }

    .stat-val.down {
      color: var(--red);
    }

    .company-link {
      color: var(--accent-bright);
      font-weight: 600;
      font-size: 13px;
      text-decoration: none;
    }

    .company-link:hover {
      text-decoration: underline;
    }

    /* Bottom Stats */
    .bottom-stats {
      background: var(--bg2);
      padding: clamp(1.5rem, 4vw, 3.75rem) 0;
      border-top: 1px solid var(--border);
    }

    .stats-row {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 32px;
      max-width: 900px;
      margin: 0 auto;
      text-align: center;
    }

    .stat-box {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }

    .stat-num {
      font-size: 36px;
      font-weight: 700;
      color: var(--accent-bright);
    }

    .stat-text {
      font-size: 14px;
      color: var(--text2);
    }

    @media (max-width: 768px) {
      .page-header h1 {
        font-size: clamp(1.5rem, 6.5vw, 1.75rem);
      }

      .page-header {
        padding: 1.5rem 0 1rem;
      }

      .company-card {
        padding: 0.9rem;
      }

      .company-stats {
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.4rem;
      }

      .stat-val {
        font-size: 0.78rem;
      }

      .stat-label-sm {
        font-size: 0.56rem;
      }

      .bottom-stats {
        padding: 1.2rem 0;
      }

      .stats-row {
        gap: 0.75rem;
        grid-template-columns: 1fr;
      }

      .stat-num {
        font-size: 1.5rem;
      }

      .companies-grid {
        grid-template-columns: 1fr;
      }

      .filter-bar {
        overflow-x: scroll;
      }
    }
  </style>
</Layout>
