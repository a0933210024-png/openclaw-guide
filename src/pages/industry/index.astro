  { id: "googl", name: "Alphabet", ticker: "GOOGL", sector: "雲端基礎設施", sectorEn: "Cloud & Infra", desc: "Google DeepMind + Gemini 模型 + GCP AI 服務，擁有 Waymo", descEn: "Google DeepMind, Gemini models, GCP AI services, and Waymo", url: "https://abc.xyz", listed: true, domain: "google.com" },
  { id: "amzn", name: "Amazon", ticker: "AMZN", sector: "雲端基礎設施", sectorEn: "Cloud & Infra", desc: "AWS Bedrock 提供 AI 模型 API，Trainium/Inferentia 自製 AI 晶片", descEn: "AWS Bedrock AI API marketplace, custom Trainium/Inferentia chips", url: "https://amazon.com", listed: true, domain: "amazon.com" },
  { id: "orcl", name: "Oracle", ticker: "ORCL", sector: "雲端基礎設施", sectorEn: "Cloud & Infra", desc: "OCI 超高速 AI 雲端基礎設施，Stargate 計畫重要夥伴", descEn: "OCI high-performance AI cloud, key Stargate project partner", url: "https://oracle.com", listed: true, domain: "oracle.com" },

  // AI 應用
