  { id: "pltr", name: "Palantir", ticker: "PLTR", sector: "AI 應用", sectorEn: "AI Applications", desc: "政府和企業 AI 數據分析平台，AIP 平台快速成長", descEn: "AI data analytics for government and enterprise, AIP platform growing fast", url: "https://palantir.com", listed: true, domain: "palantir.com" },
  { id: "crm", name: "Salesforce", ticker: "CRM", sector: "AI 應用", sectorEn: "AI Applications", desc: "企業 CRM 龍頭，Agentforce AI 代理引領企業自動化新趨勢", descEn: "CRM leader with Agentforce AI agents for enterprise automation", url: "https://salesforce.com", listed: true, domain: "salesforce.com" },
  { id: "path", name: "UiPath", ticker: "PATH", sector: "AI 應用", sectorEn: "AI Applications", desc: "RPA 機器人流程自動化龍頭，整合 AI 推進 Agentic 自動化", descEn: "RPA leader integrating AI for agentic business automation", url: "https://uipath.com", listed: true, domain: "uipath.com" },
