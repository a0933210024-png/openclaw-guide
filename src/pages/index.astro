---
import Layout from '../layouts/Layout.astro';
import fomoData from '../data/fomo.json';

const fomoTone = fomoData.fomoIndex >= 60 ? 'BULLISH' : fomoData.fomoIndex <= 40 ? 'BEARISH' : 'MIXED';
const fomoToneClass = fomoTone === 'BULLISH' ? 'fomo-green' : fomoTone === 'BEARISH' ? 'fomo-red' : 'fomo-amber';
const latestItems = fomoData.items.slice(0, 6);
---

<Layout 
  title="Home" 
  lang="en" 
  currentPath="/" 
  description="Master the AI Industry. Track 34 major AI companies, daily news, and beginner guides."
>
  <!-- Hero Section -->
  <section class="hero relative overflow-hidden">
    <!-- 背景裝飾與漸層光暈 -->
    <div class="glow-obj glow-top"></div>
    <div class="glow-obj glow-mid"></div>

    <div class="hero-container relative z-10">
      <div class="badge badge-hero mb-6">
        <span class="live-dot"></span>
        <span class="text-xs uppercase tracking-widest font-bold">System Online &bull; v2.0</span>
      </div>

      <h1 class="hero-title">
        The Autonomous<br/>
        <span class="text-gradient">AI Intelligence</span> Hub.
      </h1>

      <p class="hero-subtitle">
        Your command center for tracking the artificial intelligence value chain. <br class="hidden sm:block"/>
        Market caps, daily neural net breakthroughs, and autonomous agent deployment guides.
      </p>

      <div class="hero-actions mt-10">
        <a href="/industry" class="btn btn-primary">
          Explore Ecosystem
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="btn-icon">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/guide/install" class="btn btn-secondary">Read Documentation</a>
      </div>
    </div>
  </section>

  <!-- Signal Strip -->
  <section class="signal-strip-wrap">
    <div class="signal-strip" role="status" aria-live="polite">
      <span class="signal-dot"></span>
      <span class="signal-text">Realtime model intelligence online · curated for operators, not noise.</span>
    </div>
  </section>

  <!-- AI News FOMO Terminal -->
  <section class="fomo-wrap">
    <div class="fomo-terminal">
      <div class="fomo-header">
        <span class="fomo-led"></span>
        <span>AI INDUSTRY NEWS FOMO INDEX</span>
        <span class="fomo-time">{new Date(fomoData.generatedAt).toLocaleString('en-US', { hour12: false })} UTC</span>
      </div>

      <div class="fomo-grid">
        <div class="fomo-main">
          <p class="fomo-line">&gt; SENTIMENT_TONE: <span class={fomoToneClass}>{fomoTone}</span></p>
          <p class="fomo-line">&gt; FOMO_INDEX: <span class={fomoToneClass}>{fomoData.fomoIndex}/100</span></p>
          <p class="fomo-line mono">&gt; ASCII_BAR: <span class="fomo-bar">{fomoData.asciiBar}</span></p>
          <p class="fomo-line">&gt; BULL/BEAR: <span class="fomo-green">{fomoData.sentimentSummary.bull}</span> / <span class="fomo-red">{fomoData.sentimentSummary.bear}</span></p>
        </div>

        <div class="fomo-feed">
          <p class="fomo-feed-title">LIVE HEADLINES</p>
          <ul>
            {latestItems.map((item) => (
              <li>
                <span class={item.sentiment === 'Bull' ? 'fomo-green' : 'fomo-red'}>[{item.sentiment.toUpperCase()}]</span>
                <span class="fomo-company"> {item.company}</span>
                <span class="fomo-headline"> — {item.headline}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Live Model Releases Timeline Section -->
  <section class="max-w-7xl mx-auto px-6 pt-24 pb-12 z-10 relative">
    <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-blue-500/20 bg-blue-500/10 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" style="box-shadow: 0 0 8px rgba(96,165,250,0.8);"></span>
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-300">Live Release Timeline</span>
    </div>
    
    <div class="timeline-container relative pl-4 mt-4 border-l border-white/10">
      <!-- 節點 1 -->
      <div class="timeline-item relative mb-8 pl-6">
        <div class="absolute -left-[5px] top-1.5 w-[9px] h-[9px] rounded-full bg-blue-400 blur-[2px]"></div>
        <div class="absolute -left-[4px] top-2 w-[7px] h-[7px] rounded-full bg-white"></div>
        <div class="text-xs font-mono text-blue-400 mb-1">Today</div>
        <h3 class="text-lg font-semibold text-white">xAI Releases Grok 1.5V</h3>
        <p class="text-sm text-gray-400 mt-1">Multi-modal capabilities now available natively with enhanced visual reasoning.</p>
      </div>
      
      <!-- 節點 2 -->
      <div class="timeline-item relative mb-8 pl-6 opacity-75">
        <div class="absolute -left-[4px] top-2 w-[7px] h-[7px] rounded-full bg-gray-600"></div>
        <div class="text-xs font-mono text-gray-500 mb-1">2 Days Ago</div>
        <h3 class="text-lg font-semibold text-gray-300">OpenAI GPT-4o Mini Expansion</h3>
        <p class="text-sm text-gray-400 mt-1">Fine-tuning tier opens for all developers on Tier 3 and above.</p>
      </div>

      <!-- 節點 3 -->
      <div class="timeline-item relative pl-6 opacity-50">
        <div class="absolute -left-[4px] top-2 w-[7px] h-[7px] rounded-full bg-gray-600"></div>
        <div class="text-xs font-mono text-gray-500 mb-1">Last Week</div>
        <h3 class="text-lg font-semibold text-gray-300">Anthropic Claude 3.5 Haiku</h3>
        <p class="text-sm text-gray-400 mt-1">The fastest model in the Opus lineup is upgraded with context caching.</p>
      </div>
    </div>
  </section>

  <!-- Features Grid Sections -->
  <section class="features py-24 px-6 max-w-7xl mx-auto z-10 relative">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Card 1 -->
      <a href="/industry" class="feature-card group">
        <div class="card-icon-wrapper">
          <svg class="w-6 h-6 text-blue-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="card-title">Value Chain Radar</h3>
        <p class="card-desc">Comprehensive tracking of 34 core infrastructure providers, foundation models, and AI ecosystem participants.</p>
        <div class="card-arrow text-sm font-semibold tracking-wide mt-6 text-gray-400 group-hover:text-blue-400 transition-colors">Access Radar &rarr;</div>
      </a>

      <!-- Card 2 -->
      <a href="/news" class="feature-card group">
        <div class="card-icon-wrapper">
          <svg class="w-6 h-6 text-blue-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <h3 class="card-title">Neural Daily Briefing</h3>
        <p class="card-desc">Categorized news streams highlighting crucial breakthroughs, funding rounds, and emerging model architectures.</p>
        <div class="card-arrow text-sm font-semibold tracking-wide mt-6 text-gray-400 group-hover:text-blue-400 transition-colors">Read Briefings &rarr;</div>
      </a>

      <!-- Card 3 -->
      <a href="/guide/install" class="feature-card group">
        <div class="card-icon-wrapper">
          <svg class="w-6 h-6 text-blue-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
        </div>
        <h3 class="card-title">Deployment Manifest</h3>
        <p class="card-desc">The official playbook for bootstrapping Local LLMs, APIs, and connecting Telegram/Discord agent networks.</p>
        <div class="card-arrow text-sm font-semibold tracking-wide mt-6 text-gray-400 group-hover:text-blue-400 transition-colors">Start Deploying &rarr;</div>
      </a>

    </div>
  </section>


  <style>
    /* Hero */
    .hero {
      padding: 8rem 1.5rem 6rem;
      min-height: 70vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .hero-container {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .badge-hero {
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.03);
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      color: var(--text-secondary);
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      backdrop-filter: blur(8px);
    }
    .live-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent-glow);
      animation: pulse 2s infinite;
    }

    .hero-title {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin-bottom: 1.5rem;
      color: #ffffff;
    }

    .text-gradient {
      background: linear-gradient(to right, #ffffff 10%, #38bdf8 80%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    }

    .hero-subtitle {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: var(--text-secondary);
      line-height: 1.6;
      max-width: 600px;
      margin: 0 auto;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.875rem 1.75rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.2s ease;
      cursor: pointer;
    }
    .btn-icon {
      transition: transform 0.2s ease;
    }
    .btn:hover .btn-icon {
      transform: translateX(4px);
    }
    
    .btn-primary {
      background: #ffffff;
      color: #000000;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.1), 0 0 24px rgba(255,255,255,0.1);
    }
    .btn-primary:hover {
      background: #e5e5e5;
      transform: translateY(-1px);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #ffffff;
    }
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.2);
    }

    /* Feature Cards */
    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      border-radius: 16px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.06), transparent 40%);
      opacity: 0;
      transition: opacity 0.5s;
      pointer-events: none;
    }
    .feature-card:hover {
      border-color: rgba(56, 189, 248, 0.3);
      background: var(--bg-card-hover);
      transform: translateY(-2px);
      box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5);
    }
    .feature-card:hover::before { opacity: 1; }

    .card-icon-wrapper {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: rgba(56, 189, 248, 0.08);
      border: 1px solid rgba(56, 189, 248, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .card-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
      letter-spacing: -0.01em;
    }
    .card-desc {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.6;
      flex: 1;
    }

    /* Tailwind polyfills & utility replacements in standard CSS */
    .max-w-7xl { max-width: 80rem; }
    .mx-auto { margin-left: auto; margin-right: auto; }
    .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
    .py-24 { padding-top: 6rem; padding-bottom: 6rem; }
    .grid { display: grid; }
    .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
    .gap-6 { gap: 1.5rem; }
    @media (min-width: 768px) { .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    @media (max-width: 640px) { .hidden.sm\:block { display: none; } }
    
    .text-green-400 { color: #4ade80; }
    .text-red-400 { color: #f87171; }
    .text-white { color: #ffffff; }
    .text-gray-300 { color: #d1d5db; }
    .border-r { border-right-width: 1px; }
    .border-white\/5 { border-color: rgba(255,255,255,0.05); }

    .fomo-wrap {
      max-width: 1100px;
      margin: 0 auto;
      padding: 0 1.5rem;
    }
    .fomo-terminal {
      border: 1px solid rgba(86, 255, 165, 0.2);
      background: linear-gradient(180deg, rgba(2,10,8,0.96), rgba(5,8,12,0.96));
      box-shadow: inset 0 0 0 1px rgba(255,255,255,0.03), 0 0 40px rgba(33, 255, 152, 0.05);
      border-radius: 14px;
      padding: 1rem 1rem 1.1rem;
      font-family: var(--font-mono);
      margin-top: 1.5rem;
    }
    .fomo-header {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      color: #9beabf;
      border-bottom: 1px dashed rgba(120,255,190,0.25);
      padding-bottom: 0.7rem;
      font-size: 0.82rem;
      letter-spacing: 0.06em;
    }
    .fomo-time {
      margin-left: auto;
      color: #7fa88f;
      font-size: 0.74rem;
    }
    .fomo-led {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #39ff9c;
      box-shadow: 0 0 8px rgba(57,255,156,0.8);
      animation: pulse 1.8s infinite;
    }
    .fomo-grid {
      display: grid;
      grid-template-columns: 1fr 1.2fr;
      gap: 1rem;
      margin-top: 0.9rem;
    }
    .fomo-main, .fomo-feed {
      border: 1px solid rgba(255,255,255,0.06);
      border-radius: 10px;
      padding: 0.8rem;
      background: rgba(0,0,0,0.26);
    }
    .fomo-line {
      color: #b3d6c2;
      font-size: 0.82rem;
      margin: 0.28rem 0;
      line-height: 1.4;
    }
    .fomo-line.mono { white-space: nowrap; overflow-x: auto; }
    .fomo-bar { color: #d4ffe5; }
    .fomo-feed-title {
      color: #86f7bc;
      font-size: 0.76rem;
      margin-bottom: 0.5rem;
      letter-spacing: 0.07em;
    }
    .fomo-feed ul {
      list-style: none;
      padding: 0;
      margin: 0;
      display: grid;
      gap: 0.35rem;
    }
    .fomo-feed li {
      font-size: 0.78rem;
      color: #b8c5bd;
      line-height: 1.4;
    }
    .fomo-company { color: #e5f7ee; }
    .fomo-headline { color: #8fa39a; }
    .fomo-green { color: #52f78e; }
    .fomo-red { color: #ff6b6b; }
    .fomo-amber { color: #f6c35b; }

    @media (max-width: 900px) {
      .fomo-grid { grid-template-columns: 1fr; }
    }

    .signal-strip-wrap {
      padding: 0 1.5rem;
      margin-top: -1.5rem;
      text-align: center;
    }
    .signal-strip {
      max-width: 780px;
      margin: 0 auto;
      display: inline-flex;
      align-items: center;
      gap: 0.7rem;
      padding: 0.7rem 1rem;
      border: 1px solid rgba(255,255,255,0.12);
      border-radius: 999px;
      background: rgba(255,255,255,0.03);
      backdrop-filter: blur(8px);
      color: #cbd5e1;
      font-size: 0.88rem;
      letter-spacing: 0.01em;
      box-shadow: 0 0 24px rgba(56,189,248,0.08);
    }
    .signal-dot {
      width: 8px;
      height: 8px;
      border-radius: 999px;
      background: #38bdf8;
      box-shadow: 0 0 12px rgba(56,189,248,0.8);
      animation: pulse 2s infinite;
    }
    .signal-text { white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }

    /* Background Ambient Lights */
    .glow-obj {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      z-index: 0;
      pointer-events: none;
    }
    .glow-top {
      top: -150px;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 300px;
      background: rgba(56, 189, 248, 0.15);
    }
    .glow-mid {
      top: 30%;
      left: 20%;
      width: 400px;
      height: 400px;
      background: rgba(59, 130, 246, 0.08);
    }

    /* Ticker styles fallback */
    .inline-flex { display: inline-flex; }
    .items-center { align-items: center; }
    .gap-2 { gap: 0.5rem; }
    .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
    .font-mono { font-family: var(--font-mono); }
    .text-sm { font-size: 0.875rem; }
    .leading-none { line-height: 1; }
    .whitespace-nowrap { white-space: nowrap; }
    .font-medium { font-weight: 500; }
  </style>
</Layout>