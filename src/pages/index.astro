---
import Layout from '../layouts/Layout.astro';
import AITreeMap from '../components/AITreeMap.astro';
---

<Layout 
  title="TERMINAL" 
  lang="en" 
  currentPath="/" 
>
  <div class="terminal-grid mono">
    
    <!-- Top Bar: Ticker -->
    <div class="ticker-bar panel border-bottom">
      <div class="ticker-track" id="ticker-track">
        <!-- Will be populated by JS -->
        <span class="ticker-placeholder">LOADING MARKET DATA...</span>
      </div>
    </div>

    <!-- Main Content Grid -->
    <div class="main-layout">
      <!-- Left Column: Main Dashboard & Visualization -->
      <div class="col-main panel border-right">
        <div class="panel-header border-bottom">
          <span class="text-orange">▶ AI_SECTOR_VALUATION_MAP</span>
          <span class="text-text2">SYS: D3.JS INTERACTIVE</span>
        </div>
        
        <div class="map-container p-4">
          <!-- Imported D3 Component built by Lisa -->
           <AITreeMap />
        </div>

        <div class="panel-header border-top border-bottom mt-auto">
          <span class="text-orange">▶ SYSTEM_METRICS</span>
        </div>
        
        <div class="stats-grid p-4">
          <div class="stat-box">
            <div class="stat-label">TRACKED_COMPANIES</div>
            <div class="stat-value text-text" id="total-companies">34</div>
          </div>
          <div class="stat-box">
            <div class="stat-label">TOTAL_MARKET_CAP (T)</div>
            <div class="stat-value text-green" id="total-marketcap">--</div>
          </div>
          <div class="stat-box">
            <div class="stat-label">WEEKLY_NEWS_EVENTS</div>
            <div class="stat-value text-accent" id="news-count">12</div>
          </div>
          <div class="stat-box">
            <div class="stat-label">LAST_SYNC</div>
            <div class="stat-value text-text2" id="last-updated">LIVE</div>
          </div>
        </div>
      </div>

      <!-- Right Column: Command modules -->
      <div class="col-side panel">
        <div class="panel-header border-bottom">
          <span class="text-orange">▶ QUICK_ACCESS_MODULES</span>
        </div>
        
        <div class="modules-list">
          <a href="/industry" class="module-card">
            <div class="module-id text-text2">[MOD_01]</div>
            <h3 class="module-title text-green">INDUSTRY_SCANNER</h3>
            <p class="module-desc">Real-time tracking of AI value chain, from infrastructure to application layer.</p>
          </a>
          
          <a href="/news" class="module-card">
            <div class="module-id text-text2">[MOD_02]</div>
            <h3 class="module-title text-red">NEWS_TERMINAL</h3>
            <p class="module-desc">Aggregated intelligence on model releases and funding rounds.</p>
          </a>
          
          <a href="/guide/install" class="module-card">
            <div class="module-id text-text2">[MOD_03]</div>
            <h3 class="module-title text-accent">DEPLOYMENT_GUIDE</h3>
            <p class="module-desc">Step-by-step instructions for hosting your own autonomous agents.</p>
          </a>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Initialize ticker with real/mock data in terminal style
    async function initTicker() {
      try {
        const res = await fetch('/stocks.json');
        if(!res.ok) throw new Error('No static data');
        const data = await res.json();
        const tickers = Object.entries(data.stocks)
          .filter(([_, s]: any) => s.price > 0)
          .map(([sym, s]: any) => ({
            symbol: sym.padEnd(6, ' '),
            price: s.price.toFixed(2).padStart(8, ' '),
            change: s.changePct,
          }));
        
        const track = document.getElementById('ticker-track');
        if (!track || !tickers.length) return;
        
        const html = tickers.map(t => {
          const up = t.change >= 0;
          const sign = up ? '+' : '';
          const colorClass = up ? 'text-green' : 'text-red';
          const chgStr = `${sign}${t.change.toFixed(2)}%`.padStart(8, ' ');
          return `<span class="ticker-item"><span class="text-orange">${t.symbol}</span> <span class="text-text">${t.price}</span> <span class="${colorClass}">${chgStr}</span></span>`;
        }).join('<span class="ticker-sep text-border-light"> | </span>');
        
        track.innerHTML = html + '<span class="ticker-sep text-border-light"> | </span>' + html;
      } catch(e) {
        // Fallback fake terminal data
        const track = document.getElementById('ticker-track');
        if(track) {
           const fake = `<span class="text-orange">NVDA  </span> <span class="text-text">  143.25</span> <span class="text-green">   +2.40%</span> <span class="ticker-sep text-border-light"> | </span> <span class="text-orange">MSFT  </span> <span class="text-text">  420.80</span> <span class="text-green">   +1.20%</span> <span class="ticker-sep text-border-light"> | </span> <span class="text-orange">META  </span> <span class="text-text">  512.30</span> <span class="text-green">   +3.10%</span> <span class="ticker-sep text-border-light"> | </span> <span class="text-orange">GOOGL </span> <span class="text-text">  164.50</span> <span class="text-red">   -0.80%</span> <span class="ticker-sep text-border-light"> | </span> <span class="text-orange">TSLA  </span> <span class="text-text">  195.70</span> <span class="text-red">   -1.50%</span>`;
           track.innerHTML = fake + '<span class="ticker-sep text-border-light"> | </span>' + fake;
        }
      }
    }
    
    initTicker();
  </script>

  <style>
    .terminal-grid {
      display: flex;
      flex-direction: column;
      height: 100%;
      background: var(--bg);
    }
    
    .panel {
      background: var(--bg2);
    }
    .border-bottom { border-bottom: 2px solid var(--border); }
    .border-top { border-top: 2px solid var(--border); }
    .border-right { border-right: 2px solid var(--border); }
    .text-orange { color: var(--accent); }
    .text-green { color: var(--green); }
    .text-red { color: var(--red); }
    .text-text { color: var(--text); }
    .text-text2 { color: var(--text2); }
    .text-border-light { color: var(--border-light); }
    .p-4 { padding: 1.5rem; }
    .mt-auto { margin-top: auto; }

    /* Ticker Bar */
    .ticker-bar {
      padding: 0.5rem 1rem;
      overflow: hidden;
      white-space: pre;
      font-size: 13px;
      background: var(--bg3);
    }
    .ticker-track {
      display: inline-block;
      animation: ticker 25s linear infinite;
    }
    @keyframes ticker {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* Layout */
    .main-layout {
      display: grid;
      grid-template-columns: 3fr 1fr;
      flex: 1;
      min-height: calc(100vh - var(--nav-height) - 40px - 40px); /* rough calc */
    }
    @media (max-width: 1024px) {
      .main-layout { grid-template-columns: 1fr; }
      .border-right { border-right: none; border-bottom: 2px solid var(--border); }
    }

    .col-main {
      display: flex;
      flex-direction: column;
    }

    .panel-header {
      padding: 0.5rem 1rem;
      font-weight: 700;
      font-size: 12px;
      display: flex;
      justify-content: space-between;
      background: var(--bg3);
    }

    .map-container {
      min-height: 450px;
      display: flex;
      align-items: center;
      justify-content: center;
      border: 1px dashed var(--border-light);
      margin: 1.5rem;
      background: var(--bg);
    }

    .stats-grid {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 1rem;
    }
    @media (max-width: 640px) {
      .stats-grid { grid-template-columns: repeat(2, 1fr); }
    }
    .stat-box {
      border: 1px solid var(--border);
      padding: 1rem;
      background: var(--bg);
    }
    .stat-label {
      font-size: 11px;
      color: var(--text2);
      margin-bottom: 0.5rem;
    }
    .stat-value {
      font-size: 24px;
      font-weight: 700;
      font-family: var(--mono);
    }

    /* Modules Sidebar */
    .col-side {
      display: flex;
      flex-direction: column;
    }
    .modules-list {
      padding: 1rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }
    .module-card {
      display: block;
      border: 1px solid var(--border);
      padding: 1.25rem;
      background: var(--bg);
      transition: all 0.1s;
    }
    .module-card:hover {
      border-color: var(--accent);
      background: var(--bg3);
    }
    .module-id {
      font-size: 10px;
      margin-bottom: 0.5rem;
      letter-spacing: 0.05em;
    }
    .module-title {
      font-size: 16px;
      margin-bottom: 0.5rem;
      font-weight: 700;
    }
    .module-desc {
      font-size: 12px;
      color: var(--text2);
      line-height: 1.5;
    }
  </style>
</Layout>
