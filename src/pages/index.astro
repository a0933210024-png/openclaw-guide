---
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Home" 
  lang="en" 
  currentPath="/" 
  description="Master the AI Industry. Track 34 major AI companies, daily news, and beginner guides."
>
  <!-- Hero Section -->
  <section class="hero relative overflow-hidden">
    <!-- 背景裝飾與漸層光暈 -->
    <div class="glow-obj glow-top"></div>
    <div class="glow-obj glow-mid"></div>

    <div class="hero-container relative z-10">
      <div class="badge badge-hero mb-6">
        <span class="live-dot"></span>
        <span class="text-xs uppercase tracking-widest font-bold">System Online &bull; v2.0</span>
      </div>

      <h1 class="hero-title">
        The Autonomous<br/>
        <span class="text-gradient">AI Intelligence</span> Hub.
      </h1>

      <p class="hero-subtitle">
        Your command center for tracking the artificial intelligence value chain. <br class="hidden sm:block"/>
        Market caps, daily neural net breakthroughs, and autonomous agent deployment guides.
      </p>

      <div class="hero-actions mt-10">
        <a href="/industry" class="btn btn-primary">
          Explore Ecosystem
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" class="btn-icon">
            <path d="M5 12h14M12 5l7 7-7 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
        <a href="/guide/install" class="btn btn-secondary">Read Documentation</a>
      </div>
    </div>
  </section>

  <!-- Market Data Tracker (Ticker Replacement) -->
  <section class="ticker-section border-y border-white/10 bg-black">
    <div class="ticker-wrapper" id="ticker-wrapper">
       <!-- Ticker populated by script -->
       <div class="p-4 text-center text-sm font-mono text-gray-500">Loading live parameters...</div>
    </div>
  </section>

  <!-- Live Model Releases Timeline Section -->
  <section class="max-w-7xl mx-auto px-6 pt-24 pb-12 z-10 relative">
    <div class="inline-flex items-center gap-2 px-3 py-1 mb-6 rounded-full border border-blue-500/20 bg-blue-500/10 backdrop-blur-sm">
      <span class="w-1.5 h-1.5 rounded-full bg-blue-400 animate-pulse" style="box-shadow: 0 0 8px rgba(96,165,250,0.8);"></span>
      <span class="text-xs font-semibold uppercase tracking-widest text-blue-300">Live Release Timeline</span>
    </div>
    
    <div class="timeline-container relative pl-4 mt-4 border-l border-white/10">
      <!-- 節點 1 -->
      <div class="timeline-item relative mb-8 pl-6">
        <div class="absolute -left-[5px] top-1.5 w-[9px] h-[9px] rounded-full bg-blue-400 blur-[2px]"></div>
        <div class="absolute -left-[4px] top-2 w-[7px] h-[7px] rounded-full bg-white"></div>
        <div class="text-xs font-mono text-blue-400 mb-1">Today</div>
        <h3 class="text-lg font-semibold text-white">xAI Releases Grok 1.5V</h3>
        <p class="text-sm text-gray-400 mt-1">Multi-modal capabilities now available natively with enhanced visual reasoning.</p>
      </div>
      
      <!-- 節點 2 -->
      <div class="timeline-item relative mb-8 pl-6 opacity-75">
        <div class="absolute -left-[4px] top-2 w-[7px] h-[7px] rounded-full bg-gray-600"></div>
        <div class="text-xs font-mono text-gray-500 mb-1">2 Days Ago</div>
        <h3 class="text-lg font-semibold text-gray-300">OpenAI GPT-4o Mini Expansion</h3>
        <p class="text-sm text-gray-400 mt-1">Fine-tuning tier opens for all developers on Tier 3 and above.</p>
      </div>

      <!-- 節點 3 -->
      <div class="timeline-item relative pl-6 opacity-50">
        <div class="absolute -left-[4px] top-2 w-[7px] h-[7px] rounded-full bg-gray-600"></div>
        <div class="text-xs font-mono text-gray-500 mb-1">Last Week</div>
        <h3 class="text-lg font-semibold text-gray-300">Anthropic Claude 3.5 Haiku</h3>
        <p class="text-sm text-gray-400 mt-1">The fastest model in the Opus lineup is upgraded with context caching.</p>
      </div>
    </div>
  </section>

  <!-- Features Grid Sections -->
  <section class="features py-24 px-6 max-w-7xl mx-auto z-10 relative">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Card 1 -->
      <a href="/industry" class="feature-card group">
        <div class="card-icon-wrapper">
          <svg class="w-6 h-6 text-blue-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
          </svg>
        </div>
        <h3 class="card-title">Value Chain Radar</h3>
        <p class="card-desc">Comprehensive tracking of 34 core infrastructure providers, foundation models, and AI ecosystem participants.</p>
        <div class="card-arrow text-sm font-semibold tracking-wide mt-6 text-gray-400 group-hover:text-blue-400 transition-colors">Access Radar &rarr;</div>
      </a>

      <!-- Card 2 -->
      <a href="/news" class="feature-card group">
        <div class="card-icon-wrapper">
          <svg class="w-6 h-6 text-blue-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9a2 2 0 00-2-2h-2m-4-3H9M7 16h6M7 8h6v4H7V8z" />
          </svg>
        </div>
        <h3 class="card-title">Neural Daily Briefing</h3>
        <p class="card-desc">Categorized news streams highlighting crucial breakthroughs, funding rounds, and emerging model architectures.</p>
        <div class="card-arrow text-sm font-semibold tracking-wide mt-6 text-gray-400 group-hover:text-blue-400 transition-colors">Read Briefings &rarr;</div>
      </a>

      <!-- Card 3 -->
      <a href="/guide/install" class="feature-card group">
        <div class="card-icon-wrapper">
          <svg class="w-6 h-6 text-blue-400 group-hover:scale-110 transition-transform duration-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4" />
          </svg>
        </div>
        <h3 class="card-title">Deployment Manifest</h3>
        <p class="card-desc">The official playbook for bootstrapping Local LLMs, APIs, and connecting Telegram/Discord agent networks.</p>
        <div class="card-arrow text-sm font-semibold tracking-wide mt-6 text-gray-400 group-hover:text-blue-400 transition-colors">Start Deploying &rarr;</div>
      </a>

    </div>
  </section>

  <script>
    // Initialize unified ticker with modern styling
    async function initTicker() {
      try {
        const res = await fetch('/stocks.json');
        if(!res.ok) throw new Error();
        const data = await res.json();
        const tickers = Object.entries(data.stocks)
          .filter(([_, s]: any) => s.price > 0)
          .map(([sym, s]: any) => ({
            symbol: sym,
            price: s.price.toFixed(2),
            change: s.changePct,
          }));
        
        const track = document.getElementById('ticker-wrapper');
        if (!track || !tickers.length) return;
        
        const itemsHtml = tickers.map(t => {
          const up = t.change >= 0;
          const sign = up ? '+' : '';
          const colorClass = up ? 'text-green-400' : 'text-red-400';
          return `
            <div class="inline-flex items-center gap-2 px-6 border-r border-white/5 font-mono text-sm leading-none whitespace-nowrap">
              <span class="text-gray-300 font-medium">${t.symbol}</span>
              <span class="text-white">${t.price}</span>
              <span class="${colorClass}">${sign}${t.change.toFixed(2)}%</span>
            </div>
          `;
        }).join('');
        
        track.innerHTML = `
          <div class="flex animate-scroll-left min-w-max">
            ${itemsHtml}${itemsHtml}
          </div>
        `;
      } catch(e) {
        // Fallback layout if no dynamic data exists in static build
         const track = document.getElementById('ticker-wrapper');
         if(track) track.innerHTML = `<div class="p-3 text-center text-xs font-mono text-gray-600">STATIC_MODE :: ENABLED</div>`;
      }
    }
    initTicker();
  </script>

  <style>
    /* Hero */
    .hero {
      padding: 8rem 1.5rem 6rem;
      min-height: 70vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      text-align: center;
    }

    .hero-container {
      max-width: 800px;
      margin: 0 auto;
      display: flex;
      flex-direction: column;
      align-items: center;
    }

    .badge-hero {
      border: 1px solid rgba(255, 255, 255, 0.1);
      background: rgba(255, 255, 255, 0.03);
      padding: 0.35rem 0.85rem;
      border-radius: 999px;
      color: var(--text-secondary);
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      backdrop-filter: blur(8px);
    }
    .live-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: var(--accent);
      box-shadow: 0 0 8px var(--accent-glow);
      animation: pulse 2s infinite;
    }

    .hero-title {
      font-size: clamp(2.5rem, 6vw, 5rem);
      font-weight: 800;
      line-height: 1.05;
      letter-spacing: -0.04em;
      margin-bottom: 1.5rem;
      color: #ffffff;
    }

    .text-gradient {
      background: linear-gradient(to right, #ffffff 10%, #38bdf8 80%);
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
      color: transparent;
    }

    .hero-subtitle {
      font-size: clamp(1rem, 2vw, 1.25rem);
      color: var(--text-secondary);
      line-height: 1.6;
      max-width: 600px;
      margin: 0 auto;
    }

    .hero-actions {
      display: flex;
      gap: 1rem;
      align-items: center;
      justify-content: center;
      flex-wrap: wrap;
    }

    /* Buttons */
    .btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      gap: 0.5rem;
      padding: 0.875rem 1.75rem;
      border-radius: 999px;
      font-weight: 600;
      font-size: 0.95rem;
      transition: all 0.2s ease;
      cursor: pointer;
    }
    .btn-icon {
      transition: transform 0.2s ease;
    }
    .btn:hover .btn-icon {
      transform: translateX(4px);
    }
    
    .btn-primary {
      background: #ffffff;
      color: #000000;
      box-shadow: 0 0 0 1px rgba(255,255,255,0.1), 0 0 24px rgba(255,255,255,0.1);
    }
    .btn-primary:hover {
      background: #e5e5e5;
      transform: translateY(-1px);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
      color: #ffffff;
    }
    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.2);
    }

    /* Feature Cards */
    .feature-card {
      background: var(--bg-card);
      border: 1px solid var(--border-light);
      border-radius: 16px;
      padding: 2rem;
      display: flex;
      flex-direction: column;
      transition: all 0.3s ease;
      position: relative;
      overflow: hidden;
    }
    .feature-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background: radial-gradient(800px circle at var(--mouse-x, 50%) var(--mouse-y, 50%), rgba(255,255,255,0.06), transparent 40%);
      opacity: 0;
      transition: opacity 0.5s;
      pointer-events: none;
    }
    .feature-card:hover {
      border-color: rgba(56, 189, 248, 0.3);
      background: var(--bg-card-hover);
      transform: translateY(-2px);
      box-shadow: 0 10px 40px -10px rgba(0,0,0,0.5);
    }
    .feature-card:hover::before { opacity: 1; }

    .card-icon-wrapper {
      width: 48px;
      height: 48px;
      border-radius: 12px;
      background: rgba(56, 189, 248, 0.08);
      border: 1px solid rgba(56, 189, 248, 0.15);
      display: flex;
      align-items: center;
      justify-content: center;
      margin-bottom: 1.5rem;
    }
    .card-title {
      font-size: 1.25rem;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 0.75rem;
      letter-spacing: -0.01em;
    }
    .card-desc {
      color: var(--text-secondary);
      font-size: 0.95rem;
      line-height: 1.6;
      flex: 1;
    }

    /* Tailwind polyfills & utility replacements in standard CSS */
    .max-w-7xl { max-width: 80rem; }
    .mx-auto { margin-left: auto; margin-right: auto; }
    .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
    .py-24 { padding-top: 6rem; padding-bottom: 6rem; }
    .grid { display: grid; }
    .grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
    .gap-6 { gap: 1.5rem; }
    @media (min-width: 768px) { .md\:grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); } }
    @media (max-width: 640px) { .hidden.sm\:block { display: none; } }
    
    .text-green-400 { color: #4ade80; }
    .text-red-400 { color: #f87171; }
    .text-white { color: #ffffff; }
    .text-gray-300 { color: #d1d5db; }
    .border-r { border-right-width: 1px; }
    .border-white\/5 { border-color: rgba(255,255,255,0.05); }

    .ticker-section { padding: 12px 0; overflow: hidden; }
    .animate-scroll-left { animation: scroll-left-linear 30s linear infinite; }
    @keyframes scroll-left-linear {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }

    /* Background Ambient Lights */
    .glow-obj {
      position: absolute;
      border-radius: 50%;
      filter: blur(100px);
      z-index: 0;
      pointer-events: none;
    }
    .glow-top {
      top: -150px;
      left: 50%;
      transform: translateX(-50%);
      width: 600px;
      height: 300px;
      background: rgba(56, 189, 248, 0.15);
    }
    .glow-mid {
      top: 30%;
      left: 20%;
      width: 400px;
      height: 400px;
      background: rgba(59, 130, 246, 0.08);
    }

    /* Ticker styles fallback */
    .inline-flex { display: inline-flex; }
    .items-center { align-items: center; }
    .gap-2 { gap: 0.5rem; }
    .px-6 { padding-left: 1.5rem; padding-right: 1.5rem; }
    .font-mono { font-family: var(--font-mono); }
    .text-sm { font-size: 0.875rem; }
    .leading-none { line-height: 1; }
    .whitespace-nowrap { white-space: nowrap; }
    .font-medium { font-weight: 500; }
  </style>
</Layout>